                        <TextBlock Text="{DynamicResource Ui_NoWatchStates}"
                                   Style="{StaticResource MutedText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
