                                                              MinHeight="26"
                                                              Margin="0,0,6,0" />
                                                    <Button Content="{DynamicResource Ui_Ban}"
                                                            Click="BanJournalTarget_Click"
                                                            Style="{StaticResource DangerButton}"
                                                            MinHeight="26"
                                                            Padding="8,0"
                                                            Margin="0,0,6,0" />
                                                    <Button Content="{DynamicResource Ui_BanKill}"
                                                            Click="BanAndKillJournalTarget_Click"
                                                            Style="{StaticResource DangerButton}"
                                                            MinHeight="26"
                                                            Padding="8,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Expander.Header>
                                        <ListView ItemsSource="{Binding Entries}"
                                                  MaxHeight="220"
                                                  Background="#11171C"
                                                  BorderBrush="{StaticResource BorderBrushSoft}"
                                                  Foreground="{StaticResource TextBrush}"
