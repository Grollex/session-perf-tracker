                                                    <GridViewColumn Header="{DynamicResource Ui_Time}" Width="72" DisplayMemberBinding="{Binding TimestampText}" />
                                                    <GridViewColumn Header="{DynamicResource Ui_Mode}" Width="96" DisplayMemberBinding="{Binding ModeText}" />
                                                    <GridViewColumn Header="{DynamicResource Ui_Profile}" Width="170" DisplayMemberBinding="{Binding ProfileText}" />
                                                    <GridViewColumn Header="{DynamicResource Ui_Metrics}" Width="300" DisplayMemberBinding="{Binding MetricsText}" />
                                                    <GridViewColumn Header="{DynamicResource Ui_Reason}" Width="360">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Reason}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding Reason}" />
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border Padding="18"
                            CornerRadius="8"
                            Background="#11171C"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1">
                        <Border.Style>
