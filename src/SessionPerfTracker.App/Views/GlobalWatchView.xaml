<UserControl x:Class="SessionPerfTracker.App.Views.GlobalWatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary Source="/SessionPerfTracker.App;component/Themes/MainWindowResources.xaml" />
    </UserControl.Resources>
<TabControl Margin="16,0,0,0"
            TabStripPlacement="Top"
            Padding="0"
            SelectedIndex="{Binding SelectedGlobalWatchSectionIndex, Mode=TwoWay}"
            ItemContainerStyle="{StaticResource SubTabItem}">
    <TabItem Header="{DynamicResource Ui_Overview}">
        <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="8" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="10" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="10" />
        <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Style="{StaticResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Ui_GlobalWatch}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,18,0" />
                <TextBlock Text="{Binding GlobalWatchLastScanText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Ui_Mode}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding GlobalWatchModes}"
                          SelectedItem="{Binding SelectedGlobalWatchMode}"
                          Width="140"
                          Margin="0,0,12,0" />
                <Button Content="{DynamicResource Ui_Refresh}"
                        Click="RefreshGlobalWatch_Click"
                        Style="{StaticResource CompactButton}" />
            </StackPanel>
        </Grid>
    </Border>

    <Border Grid.Row="2" Style="{StaticResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Ui_TopCpu}" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding TopCpuOffenders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,0,0,3">
                                <Border DockPanel.Dock="Right"
                                        Padding="6,1"
                                        CornerRadius="6"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#142A1D" />
                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                    <Setter Property="Background" Value="#2A2512" />
                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                    <Setter Property="Background" Value="#2A1F14" />
                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                    <Setter Property="Background" Value="#2B1719" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                </Border>
                                <TextBlock Text="{Binding TopCpuText}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource Ui_TopRam}" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding TopRamOffenders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,0,0,3">
                                <Border DockPanel.Dock="Right"
                                        Padding="6,1"
                                        CornerRadius="6"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#142A1D" />
                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                    <Setter Property="Background" Value="#2A2512" />
                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                    <Setter Property="Background" Value="#2A1F14" />
                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                    <Setter Property="Background" Value="#2B1719" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                </Border>
                                <TextBlock Text="{Binding TopRamText}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="{DynamicResource Ui_TopDisk}" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding TopDiskOffenders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,0,0,3">
                                <Border DockPanel.Dock="Right"
                                        Padding="6,1"
                                        CornerRadius="6"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#142A1D" />
                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                    <Setter Property="Background" Value="#2A2512" />
                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                    <Setter Property="Background" Value="#2A1F14" />
                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                    <Setter Property="Background" Value="#2B1719" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                </Border>
                                <TextBlock Text="{Binding TopDiskText}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Border>

    <Grid Grid.Row="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid>
            <TextBox Text="{Binding GlobalWatchFilterText, UpdateSourceTrigger=PropertyChanged}"
                     MinHeight="32" />
            <TextBlock Text="{DynamicResource Ui_SearchProcessName}"
                       IsHitTestVisible="False"
                       Foreground="{StaticResource PlaceholderBrush}"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding GlobalWatchFilterText}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal">
            <CheckBox Content="{DynamicResource Ui_OnlyOverLimit}"
                      IsChecked="{Binding GlobalWatchOnlyOverLimit}"
                      Margin="0,0,18,0" />
            <CheckBox Content="{DynamicResource Ui_OnlyCritical}"
                      IsChecked="{Binding GlobalWatchOnlyCritical}"
                      Margin="0,0,18,0" />
            <CheckBox Content="{DynamicResource Ui_OnlyNearLimit}"
                      IsChecked="{Binding GlobalWatchOnlyNearLimit}"
                      Margin="0,0,18,0" />
            <CheckBox Content="{DynamicResource Ui_OnlyUnassigned}"
                      IsChecked="{Binding GlobalWatchOnlyUnassigned}" />
        </StackPanel>
    </Grid>

    <Grid Grid.Row="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Panel}">
            <Grid>
                <ListView ItemsSource="{Binding GlobalWatchProcesses}"
                          SelectedItem="{Binding SelectedGlobalProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="SelectionKey"
                          IsSynchronizedWithCurrentItem="False"
                          Background="#11171C"
                          BorderBrush="{StaticResource BorderBrushSoft}"
                          Foreground="{StaticResource TextBrush}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="250">
                                <GridViewColumn.Header>
                                    <Button x:Name="GlobalWatchProcessHeaderButton"
                                            Content="{Binding GlobalWatchProcessHeaderText}"
                                            Click="SortGlobalWatchProcess_Click"
                                            Style="{StaticResource TableHeaderSortButton}" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="90" DisplayMemberBinding="{Binding PidOrCountText}">
                                <GridViewColumn.Header>
                                    <Button x:Name="GlobalWatchPidHeaderButton"
                                            Content="{Binding GlobalWatchPidHeaderText}"
                                            Click="SortGlobalWatchPid_Click"
                                            Style="{StaticResource TableHeaderSortButton}" />
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="78" DisplayMemberBinding="{Binding CpuText}">
                                <GridViewColumn.Header>
                                    <Button x:Name="GlobalWatchCpuHeaderButton"
                                            Content="{Binding GlobalWatchCpuHeaderText}"
                                            Click="SortGlobalWatchCpu_Click"
                                            Style="{StaticResource TableHeaderSortButton}" />
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="110" DisplayMemberBinding="{Binding MemoryText}">
                                <GridViewColumn.Header>
                                    <Button x:Name="GlobalWatchRamHeaderButton"
                                            Content="{Binding GlobalWatchRamHeaderText}"
                                            Click="SortGlobalWatchRam_Click"
                                            Style="{StaticResource TableHeaderSortButton}" />
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="110" DisplayMemberBinding="{Binding DiskTotalText}">
                                <GridViewColumn.Header>
                                    <Button x:Name="GlobalWatchDiskHeaderButton"
                                            Content="{Binding GlobalWatchDiskHeaderText}"
                                            Click="SortGlobalWatchDisk_Click"
                                            Style="{StaticResource TableHeaderSortButton}" />
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="104">
                                <GridViewColumn.Header>
                                    <Button x:Name="GlobalWatchProfileHeaderButton"
                                            Content="{Binding GlobalWatchProfileHeaderText}"
                                            Click="SortGlobalWatchProfile_Click"
                                            Style="{StaticResource TableHeaderSortButton}" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="7,2"
                                                CornerRadius="7"
                                                Background="#1B2630"
                                                BorderBrush="#34566A"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding ProfileBadgeText}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="92">
                                <GridViewColumn.Header>
                                    <Button x:Name="GlobalWatchHealthHeaderButton"
                                            Content="{Binding GlobalWatchHealthHeaderText}"
                                            Click="SortGlobalWatchHealth_Click"
                                            Style="{StaticResource TableHeaderSortButton}" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="7,2"
                                                CornerRadius="7"
                                                BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#142A1D" />
                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                            <Setter Property="Background" Value="#2A2512" />
                                                            <Setter Property="BorderBrush" Value="#A88423" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                            <Setter Property="Background" Value="#2A1F14" />
                                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                            <Setter Property="Background" Value="#2B1719" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding HealthBadgeText}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                <Border Padding="18"
                        CornerRadius="8"
                        Background="#11171C"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasGlobalWatchRows}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding GlobalWatchEmptyStateText}"
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource Panel}">
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          PanningMode="VerticalOnly">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding SelectedGlobalProcessPanelTitle}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <TextBlock Text="{Binding SelectedGlobalProcessTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="42"
                               ToolTip="{Binding SelectedGlobalProcessTitle}" />
                    <TextBlock Text="{Binding SelectedGlobalProcessHint}"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,14" />

                    <TextBlock Text="{DynamicResource Ui_Identity}"
                               Style="{StaticResource MutedText}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="{DynamicResource Ui_Product}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedGlobalProcessProductText}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SelectedGlobalProcessProductText}" />
                        <TextBlock Grid.Row="2" Text="{DynamicResource Ui_Exe}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGlobalProcessExeText}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="4" Text="{DynamicResource Ui_Path}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Text="{Binding SelectedGlobalProcessPathText}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SelectedGlobalProcessPathText}" />
                        <TextBlock Grid.Row="6" Text="{DynamicResource Ui_Description}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Text="{Binding SelectedGlobalProcessDescriptionText}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SelectedGlobalProcessDescriptionText}" />
                        <TextBlock Grid.Row="8" Text="{DynamicResource Ui_Company}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedGlobalProcessCompanyText}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="10" Text="{DynamicResource Ui_Signer}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding SelectedGlobalProcessSignerText}" />
                        <TextBlock Grid.Row="12" Text="{DynamicResource Ui_Parent}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SelectedGlobalProcessParentText}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="14" Text="{DynamicResource Ui_Tree}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding SelectedGlobalProcessDescendantsText}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="16" Text="{DynamicResource Ui_CPU}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding SelectedGlobalProcessCpuText}" />
                        <TextBlock Grid.Row="18" Text="{DynamicResource Ui_RAM}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="18" Grid.Column="1" Text="{Binding SelectedGlobalProcessRamText}" />
                        <TextBlock Grid.Row="20" Text="{DynamicResource Ui_DiskReadWrite}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="20" Grid.Column="1" Text="{Binding SelectedGlobalProcessDiskText}" />
                        <TextBlock Grid.Row="22" Text="{DynamicResource Ui_Profile}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="22" Grid.Column="1" Text="{Binding SelectedGlobalProcessProfileText}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="24" Text="{DynamicResource Ui_Health}" Style="{StaticResource MutedText}" />
                        <Border Grid.Row="24"
                                Grid.Column="1"
                                Padding="7,2"
                                CornerRadius="7"
                                HorizontalAlignment="Left"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#142A1D" />
                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Near">
                                            <Setter Property="Background" Value="#2A2512" />
                                            <Setter Property="BorderBrush" Value="#A88423" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Over">
                                            <Setter Property="Background" Value="#2A1F14" />
                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Critical">
                                            <Setter Property="Background" Value="#2B1719" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SelectedGlobalProcessHealthText}" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Grid.Row="26" Text="{DynamicResource Ui_Reason}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="26" Grid.Column="1" Text="{Binding SelectedGlobalProcessReasonText}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="28" Text="{DynamicResource Ui_Included}" Style="{StaticResource MutedText}" />
                        <TextBlock Grid.Row="28"
                                   Grid.Column="1"
                                   Text="{Binding SelectedGlobalProcessIncludedText}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock Text="{DynamicResource Ui_Actions}"
                               Style="{StaticResource MutedText}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <Button Content="{DynamicResource Ui_MonitorProcessGroup}"
                            Click="MonitorGlobalProcess_Click"
                            IsEnabled="{Binding CanMonitorSelectedGlobalProcess}" />
                    <Button Content="{DynamicResource Ui_ViewDetails}"
                            Click="OpenGlobalProcessInspector_Click"
                            IsEnabled="{Binding CanInspectSelectedGlobalProcess}"
                            Style="{StaticResource CompactButton}"
                            Margin="0,8,0,0" />
                    <UniformGrid Columns="2" Margin="0,8,0,0">
                        <Button Content="{DynamicResource Ui_KillPid}"
                                Click="KillGlobalProcess_Click"
                                IsEnabled="{Binding CanKillSelectedGlobalProcess}"
                                Style="{StaticResource DangerButton}"
                                Margin="0,0,6,0" />
                        <Button Content="{Binding SelectedGlobalProcessKillTreeLabel}"
                                Click="KillGlobalProcessTree_Click"
                                IsEnabled="{Binding CanKillSelectedGlobalProcess}"
                                Style="{StaticResource DangerButton}" />
                    </UniformGrid>
                     <DockPanel Margin="0,10,0,0">
                         <Button DockPanel.Dock="Right"
                                 Content="{DynamicResource Ui_Assign}"
                                 Click="AssignGlobalWatchProfile_Click"
                                IsEnabled="{Binding CanAssignSelectedGlobalProcessProfile}"
                                MinHeight="30"
                                Padding="10,0"
                                Margin="8,0,0,0" />
                        <ComboBox ItemsSource="{Binding ThresholdProfiles}"
                                  SelectedItem="{Binding SelectedLiveAssignmentProfile}"
                                  DisplayMemberPath="DisplayName"
                                   IsEnabled="{Binding CanAssignSelectedGlobalProcessProfile}" />
                     </DockPanel>
                    <Border Margin="0,10,0,0"
                            Padding="9"
                            CornerRadius="8"
                            Background="#171414"
                            BorderBrush="{StaticResource BadBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_ProcessBan}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SelectedGlobalProcessBanText}"
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" />
                            <ComboBox ItemsSource="{Binding ProcessBanDurationOptions}"
                                      SelectedItem="{Binding SelectedProcessBanDurationOption}"
                                      DisplayMemberPath="Label"
                                      IsEnabled="{Binding CanBanSelectedGlobalProcess}"
                                      Margin="0,8,0,0" />
                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <Button Content="{DynamicResource Ui_Ban}"
                                        Click="BanGlobalProcess_Click"
                                        IsEnabled="{Binding CanBanSelectedGlobalProcess}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,0" />
                                <Button Content="{DynamicResource Ui_BanKill}"
                                        Click="BanAndKillGlobalProcess_Click"
                                        IsEnabled="{Binding CanBanSelectedGlobalProcess}"
                                        Style="{StaticResource DangerButton}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,10,0,0"
                            Padding="9"
                            CornerRadius="8"
                            Background="#12191F"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_SuspiciousWatchlist}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SelectedGlobalProcessSuspiciousText}"
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" />
                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <Button Content="{DynamicResource Ui_Mark}"
                                        Click="MarkGlobalWatchSuspicious_Click"
                                        IsEnabled="{Binding CanMarkSelectedGlobalProcessSuspicious}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,0" />
                                <Button Content="{DynamicResource Ui_Remove}"
                                        Click="RemoveGlobalWatchSuspicious_Click"
                                        IsEnabled="{Binding CanRemoveSelectedGlobalProcessSuspicious}"
