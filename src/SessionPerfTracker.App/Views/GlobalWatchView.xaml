                                                            Style="{StaticResource CompactButton}"
                                                            MinHeight="26"
                                                            Padding="8,0"
                                                            Margin="0,0,6,0" />
                                                    <ComboBox ItemsSource="{Binding DataContext.ProcessBanDurationOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding DataContext.SelectedProcessBanDurationOption, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
