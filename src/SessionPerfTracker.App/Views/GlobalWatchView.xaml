                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasGlobalWatchJournalGroups}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
