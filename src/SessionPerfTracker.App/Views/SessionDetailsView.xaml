<UserControl x:Class="SessionPerfTracker.App.Views.SessionDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary Source="/SessionPerfTracker.App;component/Themes/MainWindowResources.xaml" />
    </UserControl.Resources>
<ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="16,0,0,0">
        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
            <StackPanel>
                <DockPanel Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{Binding SessionDetailTitle}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SessionDetailSubtitle}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Content="{DynamicResource Ui_BackToSessions}"
                            Click="BackToSessions_Click"
                            Style="{StaticResource CompactButton}" />
                </DockPanel>

                <TextBlock Text="{DynamicResource Ui_SessionDetailsHint}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSessionDetails}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding SessionDetailFacts}"
                              Visibility="{Binding HasSessionDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12"
                                    Margin="0,0,10,10"
                                    CornerRadius="8"
                                    Background="#141A1F"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}" Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding Value}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
            <StackPanel>
                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="{DynamicResource Ui_MetricOverview}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{DynamicResource Ui_RecordedMetricsOnly}"
                               Style="{StaticResource MutedText}" />
                </DockPanel>

                <ItemsControl ItemsSource="{Binding SessionDetailMetricSummaries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12"
                                    Margin="0,0,0,8"
                                    CornerRadius="8"
                                    Background="#141A1F"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding MinLabel}" />
                                    <TextBlock Grid.Column="2" Text="{Binding AvgLabel}" />
                                    <TextBlock Grid.Column="3" Text="{Binding MaxLabel}" />
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{Binding SpikeLabel}" />
                                        <TextBlock Text="{Binding BreachLabel}" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{DynamicResource Ui_NoMetricSummaries}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSessionDetailMetrics}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Padding="12"
                        Margin="0,10,0,0"
                        CornerRadius="8"
                        Background="#11171C"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_NotShownRecorded}" Style="{StaticResource MutedText}" />
                        <ItemsControl ItemsSource="{Binding SessionDetailUnsupportedMetricNotices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Panel}">
            <StackPanel>
                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="{DynamicResource Ui_TimelineEventReview}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{DynamicResource Ui_Chronological}"
                               Style="{StaticResource MutedText}" />
                </DockPanel>

                <ItemsControl ItemsSource="{Binding SessionDetailEvents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12"
                                    Margin="0,0,0,10"
                                    CornerRadius="8"
                                    Background="#141A1F"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Style="{StaticResource MutedText}">
                                                <Run Text="{Binding ElapsedText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding TimestampText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding Metric, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding Kind, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding ObservedText}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding ThresholdText}"
                                                       Style="{StaticResource MutedText}"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Margin="0,8,0,0"
                                            Padding="8"
                                            CornerRadius="6"
                                            Background="#1B252D"
                                            BorderBrush="#34566A"
                                            BorderThickness="1"
                                            Visibility="{Binding IsGrouped, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding GroupedText}" Style="{StaticResource MutedText}" />
                                    </Border>

                                    <TextBlock Text="{Binding Details}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0" />

                                    <Expander Header="{DynamicResource Ui_ContextAroundEvent}"
                                              Foreground="{StaticResource TextBrush}"
                                              Background="#11171C"
                                              Margin="0,10,0,0"
                                              Visibility="{Binding HasContext, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border Padding="10"
                                                CornerRadius="8"
                                                Background="#11171C"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ContextCapturedText}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding ContextNoteText}" Style="{StaticResource MutedText}" Margin="0,2,0,10" />

                                                <TextBlock Text="{DynamicResource Ui_TopCpuNearby}" FontWeight="SemiBold" />
                                                <ItemsControl ItemsSource="{Binding TopCpuContext}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding SummaryText}"
                                                                       Style="{StaticResource MutedText}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{DynamicResource Ui_TopRamNearby}" FontWeight="SemiBold" Margin="0,10,0,0" />
                                                <ItemsControl ItemsSource="{Binding TopRamContext}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding SummaryText}"
                                                                       Style="{StaticResource MutedText}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{DynamicResource Ui_TopDiskNearby}" FontWeight="SemiBold" Margin="0,10,0,0" />
                                                <ItemsControl ItemsSource="{Binding TopDiskContext}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding SummaryText}"
                                                                       Style="{StaticResource MutedText}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <StackPanel Margin="0,10,0,0"
                                                            Visibility="{Binding HasNewProcessContext, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{DynamicResource Ui_NewProcessesNearby}" FontWeight="SemiBold" />
                                                    <ItemsControl ItemsSource="{Binding NewProcessContext}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{DynamicResource Ui_NoDetectorEvents}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSessionDetailEvents}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</ScrollViewer>
</UserControl>
