<UserControl x:Class="SessionPerfTracker.App.Views.SessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary Source="/SessionPerfTracker.App;component/Themes/MainWindowResources.xaml" />
    </UserControl.Resources>
<Grid Margin="16,0,0,0">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340" />
        <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,14,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Ui_SavedSessions}" Style="{StaticResource SectionTitle}" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{DynamicResource Ui_OpenDetails}"
                            Click="OpenSessionDetails_Click"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0,0,8,0" />
                    <Button Content="{DynamicResource Ui_Refresh}"
                            Click="RefreshSessions_Click"
                            Style="{StaticResource ToolbarButton}" />
                </StackPanel>
            </DockPanel>
            <Border Grid.Row="1" Style="{StaticResource ToolbarPanel}" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <TextBox Text="{Binding SessionSearchText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <TextBlock Text="{DynamicResource Ui_SearchSessions}"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource PlaceholderBrush}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SessionSearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <DockPanel Margin="0,8,0,0">
                    <TextBlock Text="{DynamicResource Ui_Profile}"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding SessionProfileFilters}"
                              SelectedItem="{Binding SelectedSessionProfileFilter}"
                              DisplayMemberPath="Label"
                              Margin="12,0,0,0" />
                </DockPanel>
            </StackPanel>
            </Border>
            <ListBox ItemsSource="{Binding Sessions}"
                     Grid.Row="2"
                     SelectedItem="{Binding SelectedSession}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource TextBrush}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding AppName}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding AppName}" />
                            <TextBlock Grid.Row="1" Style="{StaticResource MutedText}">
                                <Run Text="{Binding StartedText, Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding DurationText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Grid.Row="2" Style="{StaticResource MutedText}">
                                <Run Text="{Binding ChildTrackingText, Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding SamplingText, Mode=OneWay}" />
                            </TextBlock>
                            <DockPanel Grid.Row="3" Margin="0,2,0,0">
                                <TextBlock Text="{Binding StabilityText}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding QualityHint}"
                                           Style="{StaticResource MutedText}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="8,0,0,0" />
                            </DockPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>

    <Border Grid.Column="1" Style="{StaticResource Panel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="{DynamicResource Ui_MetricSummary}" Style="{StaticResource SectionTitle}" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="{DynamicResource Ui_ExportHtml}"
                                Click="ExportSelectedSessionHtml_Click"
                                Style="{StaticResource ToolbarButton}"
                                Margin="0,0,8,0" />
                        <Button Content="{DynamicResource Ui_ExportCsv}"
                                Click="ExportSelectedSessionCsv_Click"
                                Style="{StaticResource ToolbarButton}" />
                    </StackPanel>
                </DockPanel>
                <TextBlock Text="{Binding ExportStatusText}"
                           Style="{StaticResource MutedText}"
                           Margin="0,0,0,12" />
                <Border Style="{StaticResource EmptyState}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedSession.StabilityText}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedSession.StabilityReason}" Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding SelectedSession.StartupText}" />
                            <TextBlock Text="{DynamicResource Ui_BestEffortReady}" Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding SelectedSession.ExitText}" />
                            <TextBlock Text="{DynamicResource Ui_BasedRecordedEvents}" Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <ItemsControl ItemsSource="{Binding SelectedMetricSummaries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource KpiTile}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding MinLabel}" />
                                    <TextBlock Grid.Column="2" Text="{Binding AvgLabel}" />
                                    <TextBlock Grid.Column="3" Text="{Binding MaxLabel}" />
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{Binding SpikeLabel}" />
                                        <TextBlock Text="{Binding BreachLabel}" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Style="{StaticResource EmptyState}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_NotCollected}" Style="{StaticResource MutedText}" />
                        <ItemsControl ItemsSource="{Binding UnsupportedMetricNotices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Grid>
</UserControl>
