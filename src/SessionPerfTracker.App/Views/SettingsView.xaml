<UserControl x:Class="SessionPerfTracker.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary Source="/SessionPerfTracker.App;component/Themes/MainWindowResources.xaml" />
    </UserControl.Resources>
<TabControl x:Name="SettingsTabs"
            Margin="16,0,0,0"
            SelectedIndex="{Binding SelectedSettingsTabIndex, Mode=TwoWay}">
    <TabItem Header="{DynamicResource Ui_Capture}">
        <ScrollViewer Style="{StaticResource PageScrollViewer}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_CollectorsCapture}" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                        <TextBlock Text="{DynamicResource Ui_SamplingSettingsHint}" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{DynamicResource Ui_SamplingHint}" Style="{StaticResource MutedText}" Margin="0,4,0,12" />
                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <CheckBox Content="{DynamicResource Ui_CPU}" IsChecked="{Binding CaptureCpu}" />
                            <CheckBox Content="{DynamicResource Ui_RAM}" IsChecked="{Binding CaptureRam}" />
                            <CheckBox Content="{DynamicResource Ui_DiskRead}" IsChecked="{Binding CaptureDiskRead}" />
                            <CheckBox Content="{DynamicResource Ui_DiskWrite}" IsChecked="{Binding CaptureDiskWrite}" />
                        </UniformGrid>
                        <TextBlock Text="{DynamicResource Ui_UnsupportedCollectorsHint}" Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                        <Button Content="{DynamicResource Ui_SaveCaptureScope}"
                                Click="SaveCaptureSettings_Click"
                                Style="{StaticResource ToolbarButton}"
                                HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding ThresholdSettingsStatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />

                        <TextBlock Text="{DynamicResource Ui_AntiNoise}" Style="{StaticResource SectionTitle}" Margin="0,22,0,12" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Ui_StartupGrace}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding StartupGraceSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            <TextBlock Grid.Column="3" Text="{DynamicResource Ui_Cooldown}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="4" Text="{Binding EventCooldownSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            <TextBlock Grid.Row="2" Text="{DynamicResource Ui_Grouping}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding GroupingWindowSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{DynamicResource Ui_SnapshotSuppress}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding SnapshotSuppressionSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            <Button Grid.Row="4" Grid.ColumnSpan="6" Content="{DynamicResource Ui_SaveAntiNoise}" Click="SaveAntiNoiseSettings_Click" HorizontalAlignment="Left" Style="{StaticResource ToolbarButton}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_SelfMonitoring}" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource Ui_SelfProcess}" />
                            <TextBlock DockPanel.Dock="Right" Text="{Binding SelfMonitoringStatusText}" Style="{StaticResource MutedText}" />
                        </DockPanel>
                        <UniformGrid Columns="2" Margin="0,0,0,18">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="{DynamicResource Ui_CpuNowAvgPeak}" Style="{StaticResource MutedText}" />
                                <TextBlock>
                                    <Run Text="{Binding SelfCurrentCpuText, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding SelfAvgCpuText, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding SelfPeakCpuText, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Ui_RamNowAvgPeak}" Style="{StaticResource MutedText}" />
                                <TextBlock>
                                    <Run Text="{Binding SelfCurrentRamText, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding SelfAvgRamText, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding SelfPeakRamText, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ui_SelfDiskWrite}" Style="{StaticResource MutedText}" />
                                <TextBlock Text="{Binding SelfDiskWriteText}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ui_Samples}" Style="{StaticResource MutedText}" />
                                <TextBlock Text="{Binding SelfSampleCountText}" />
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="{DynamicResource Ui_OverheadBudget}" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="{DynamicResource Ui_AvgCpuBudget}" Style="{StaticResource MutedText}" />
                                <TextBlock Text="{Binding SelfCpuBudgetStatusText}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Ui_PeakRamBudget}" Style="{StaticResource MutedText}" />
                                <TextBlock Text="{Binding SelfRamBudgetStatusText}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ui_WritesBatched}" Style="{StaticResource MutedText}" />
                                <TextBlock Text="{Binding SelfWritesBudgetStatusText}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ui_DeepSnapshots}" Style="{StaticResource MutedText}" />
                                <TextBlock Text="{Binding SelfSnapshotsBudgetStatusText}" />
                            </StackPanel>
                        </UniformGrid>
                        <Border Margin="0,18,0,0"
                                Padding="12"
                                CornerRadius="8"
                                Background="#11171C"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ui_AppBehavior}" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                                <CheckBox Content="{DynamicResource Ui_KeepRunningBackground}"
                                          IsChecked="{Binding MinimizeToTrayOnClose}" />
                                <CheckBox Content="{DynamicResource Ui_StartWithWindows}"
                                          IsChecked="{Binding StartWithWindows}"
                                          Margin="0,8,0,0" />
                                <CheckBox Content="{DynamicResource Ui_StartMinimizedToTray}"
                                          IsChecked="{Binding StartMinimizedToTray}"
                                          Margin="0,8,0,0" />
                                <TextBlock Text="{DynamicResource Ui_AppBehaviorHint}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,6,0,10" />
                                <Button Content="{DynamicResource Ui_SaveAppBehavior}"
                                        Click="SaveAppBehaviorSettings_Click"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource ToolbarButton}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,12,0,0"
                                Padding="12"
                                CornerRadius="8"
                                Background="#11171C"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ui_Language}" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                          SelectedItem="{Binding SelectedLanguageOption}"
                                          DisplayMemberPath="DisplayName"
                                          MaxWidth="220"
                                          HorizontalAlignment="Left" />
                                <Button Content="{DynamicResource Ui_SaveLanguage}"
                                        Click="SaveLanguageSettings_Click"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource ToolbarButton}"
                                        Margin="0,10,0,0" />
                                <TextBlock Text="{Binding LanguageSettingsStatusText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </TabItem>

    <TabItem Header="{DynamicResource Ui_Profiles}">
        <ScrollViewer Style="{StaticResource PageScrollViewer}">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                <TextBlock Text="{DynamicResource Ui_ThresholdProfiles}" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                <TextBlock Text="{DynamicResource Ui_GlobalFallback}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Ui_CpuPercent}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding CpuThresholdPercentText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <TextBlock Grid.Column="3" Text="{DynamicResource Ui_RamMb}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="4"
                             Text="{Binding RamThresholdMbText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <TextBlock Grid.Row="2" Text="{DynamicResource Ui_DiskReadRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding DiskReadThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{DynamicResource Ui_DiskWriteRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2"
                             Grid.Column="4"
                             Text="{Binding DiskWriteThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <Button Grid.Column="5"
                            Grid.RowSpan="3"
                            Content="{DynamicResource Ui_SaveFallback}"
                            Click="SaveThresholdSettings_Click"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0" />
                </Grid>

                <Grid Margin="0,0,0,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Ui_SelectedProfile}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              Grid.ColumnSpan="2"
                              ItemsSource="{Binding ThresholdProfiles}"
                              SelectedItem="{Binding SelectedThresholdProfile}"
                              DisplayMemberPath="DisplayName"
                              Margin="0" />
                    <Button Grid.Column="3"
                            Content="{DynamicResource Ui_ResetSelected}"
                            Click="ResetSelectedProfile_Click"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Left" />
                    <Button Grid.Column="4"
                            Grid.ColumnSpan="2"
                            Content="{DynamicResource Ui_ResetAllThresholds}"
                            Click="ResetAllThresholdSettings_Click"
                            Style="{StaticResource DangerButton}"
                            HorizontalAlignment="Left" />

                    <TextBlock Grid.Row="2" Text="{DynamicResource Ui_CpuPercent}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding ProfileCpuThresholdPercentText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{DynamicResource Ui_RamMb}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2"
                             Grid.Column="4"
                             Text="{Binding ProfileRamThresholdMbText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />

                    <TextBlock Grid.Row="4" Text="{DynamicResource Ui_DiskReadRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Text="{Binding ProfileDiskReadThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <TextBlock Grid.Row="4" Grid.Column="3" Text="{DynamicResource Ui_DiskWriteRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4"
                             Grid.Column="4"
                             Text="{Binding ProfileDiskWriteThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <Button Grid.Row="4"
                            Grid.Column="5"
                            Content="{DynamicResource Ui_SaveProfile}"
                            Click="SaveSelectedProfile_Click"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Left"
                            Margin="14,0,0,0" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Ui_AppAssignment}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding AssignmentExeNameText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="32" />
                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding ThresholdProfiles}"
                              SelectedItem="{Binding SelectedAssignmentProfile}"
                              DisplayMemberPath="DisplayName"
                              Margin="0" />
                    <Button Grid.Column="4"
                            Content="{DynamicResource Ui_Assign}"
                            Click="SaveAppProfileAssignment_Click"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Left"
                            Margin="14,0,0,0" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ListBox ItemsSource="{Binding AppProfileAssignments}"
                             SelectedItem="{Binding SelectedAppProfileAssignment}"
                             DisplayMemberPath="DisplayText"
                             MinHeight="72"
                             MaxHeight="140"
                             Background="#11171C"
                             BorderBrush="{StaticResource BorderBrushSoft}"
                             Foreground="{StaticResource TextBrush}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <Button Grid.Column="1"
                            Content="{DynamicResource Ui_RemoveAssignment}"
                            Click="RemoveAppProfileAssignment_Click"
                            Style="{StaticResource TertiaryButton}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="14,0,0,0" />
                </Grid>
                <TextBlock Text="{Binding ThresholdSettingsStatusText}" Style="{StaticResource MutedText}" Margin="0,0,0,18" />

            </StackPanel>
        </Border>
        </ScrollViewer>
    </TabItem>

    <TabItem Header="{DynamicResource Ui_Storage}">
        <ScrollViewer Style="{StaticResource PageScrollViewer}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_StorageRetention}" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource Ui_Retention}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource Ui_Save}"
                                    Click="SaveRetentionSettings_Click"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="8,0,0,0" />
                            <ComboBox ItemsSource="{Binding RetentionOptions}"
                                      SelectedItem="{Binding SelectedRetentionOption}"
                                      DisplayMemberPath="Label"
                                      Margin="12,0,0,0" />
                        </DockPanel>
                        <Border Style="{StaticResource DangerPanel}" Margin="0,0,0,8">
                            <UniformGrid Columns="2">
                                <Button Content="{DynamicResource Ui_DeleteAllSessions}" Click="DeleteAllSessions_Click" Style="{StaticResource DangerButton}" Margin="0,0,8,8" />
                                <Button Content="{DynamicResource Ui_DeleteFilteredSessions}" Click="DeleteFilteredSessions_Click" Style="{StaticResource DangerButton}" Margin="0,0,0,8" />
                                <Button Content="{DynamicResource Ui_DeleteOlder1}" Click="DeleteSessionsOlderThan1Day_Click" Style="{StaticResource DangerButton}" Margin="0,0,8,8" />
                                <Button Content="{DynamicResource Ui_DeleteOlder7}" Click="DeleteSessionsOlderThan7Days_Click" Style="{StaticResource DangerButton}" Margin="0,0,0,8" />
                                <Button Content="{DynamicResource Ui_DeleteOlder30}" Click="DeleteSessionsOlderThan30Days_Click" Style="{StaticResource DangerButton}" Margin="0,0,8,0" />
                            </UniformGrid>
                        </Border>
                        <TextBlock Text="{Binding StorageStatusText}" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding StoragePath}" Style="{StaticResource MutedText}" Margin="0,14,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_Exports}" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                        <TextBlock Text="{DynamicResource Ui_Folder}" Style="{StaticResource MutedText}" />
                        <DockPanel Margin="0,6,0,8">
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource Ui_Browse}"
                                    Click="BrowseExportDirectory_Click"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="8,0,0,0" />
                            <TextBox Text="{Binding ExportDirectoryText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                        </DockPanel>
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Button Content="{DynamicResource Ui_SaveFolder}" Click="SaveExportDirectory_Click" Style="{StaticResource ToolbarButton}" Margin="0,0,8,8" />
                            <Button Content="{DynamicResource Ui_DefaultFolder}" Click="ResetExportDirectory_Click" Style="{StaticResource ToolbarButton}" Margin="0,0,8,8" />
                            <Button Content="{DynamicResource Ui_OpenFolder}" Click="OpenExportDirectory_Click" Style="{StaticResource ToolbarButton}" Margin="0,0,0,8" />
                        </UniformGrid>
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8">
                            <Run Text="{DynamicResource Ui_DefaultPrefix}" />
                            <Run Text="{Binding DefaultExportDirectoryText, Mode=OneWay}" />
                        </TextBlock>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource Ui_ExportFiles}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="{DynamicResource Ui_Refresh}" Click="RefreshExports_Click" Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" />
                                <Button Content="{DynamicResource Ui_OpenSelected}" Click="OpenSelectedExport_Click" Style="{StaticResource ToolbarButton}" />
                            </StackPanel>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding ExportFiles}"
                                 SelectedItem="{Binding SelectedExportFile}"
                                 DisplayMemberPath="DisplayText"
                                 MinHeight="84"
                                 MaxHeight="220"
                                 Background="#11171C"
                                 BorderBrush="{StaticResource BorderBrushSoft}"
                                 Foreground="{StaticResource TextBrush}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        <TextBlock Text="{Binding ExportStatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_Updates}" Style="{StaticResource SectionTitle}" Margin="0,0,0,14" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Ui_CurrentVersion}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding CurrentVersionText}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{DynamicResource Ui_Latest}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding UpdateLatestVersionText}" VerticalAlignment="Center" />
                        </Grid>
                        <CheckBox Content="{DynamicResource Ui_AutoCheckUpdates}"
                                  IsChecked="{Binding AutomaticallyCheckForUpdates}"
                                  Margin="0,0,0,10" />
                        <CheckBox Content="{DynamicResource Ui_AutoInstallUpdatesStartup}"
                                  IsChecked="{Binding AutomaticallyInstallUpdatesOnStartup}"
                                  Margin="0,0,0,10" />
                        <TextBlock Text="{DynamicResource Ui_ManifestUrl}" Style="{StaticResource MutedText}" />
                        <TextBox Text="{Binding UpdateManifestUrlText, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="32"
                                 Margin="0,6,0,10" />
                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="{DynamicResource Ui_SaveUpdateSettings}"
                                    Click="SaveUpdateSettings_Click"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource Ui_CheckUpdates}"
                                    Click="CheckForUpdates_Click"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource Ui_DownloadRunInstaller}"
                                    Click="DownloadAndLaunchUpdate_Click"
                                    IsEnabled="{Binding CanDownloadUpdateInstaller}"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource Ui_SkipVersion}"
                                    Click="SkipUpdate_Click"
                                    IsEnabled="{Binding CanSkipAvailableUpdate}"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DownloadedUpdateInstallerPath}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,8"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DownloadedUpdateInstallerPath}" />
                        <TextBlock Text="{DynamicResource Ui_ReleaseNotes}" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding UpdateReleaseNotesText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 MinHeight="72"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </TabItem>

    <TabItem Header="{DynamicResource Ui_Feedback}">
        <ScrollViewer Style="{StaticResource PageScrollViewer}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_ReportBug}" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                        <TextBlock Text="{DynamicResource Ui_ReportBugHint}" Style="{StaticResource MutedText}" Margin="0,0,0,10" />
                        <TextBox Text="{Binding BugReportText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="220"
                                 VerticalScrollBarVisibility="Auto" />
                        <CheckBox Content="{DynamicResource Ui_AttachLatestSession}"
                                  IsChecked="{Binding IncludeLatestSessionInFeedback}"
                                  Margin="0,10,0,0" />
                        <CheckBox Content="{DynamicResource Ui_AttachScreenshot}"
                                  IsChecked="{Binding IncludeScreenshotInFeedback}"
                                  Margin="0,6,0,0" />
                        <TextBlock Text="{DynamicResource Ui_FeedbackPrivacyCopy}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                        <Button Content="{DynamicResource Ui_SendBugReport}"
                                Click="SaveBugReport_Click"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0"
                                Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_SendIdea}" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                        <TextBlock Text="{DynamicResource Ui_SendIdeaHint}" Style="{StaticResource MutedText}" Margin="0,0,0,10" />
                        <TextBox Text="{Binding FeatureFeedbackText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="220"
                                 VerticalScrollBarVisibility="Auto" />
                        <CheckBox Content="{DynamicResource Ui_AttachLatestSession}"
                                  IsChecked="{Binding IncludeLatestSessionInFeedback}"
                                  Margin="0,10,0,0" />
                        <CheckBox Content="{DynamicResource Ui_AttachScreenshot}"
                                  IsChecked="{Binding IncludeScreenshotInFeedback}"
                                  Margin="0,6,0,0" />
                        <TextBlock Text="{DynamicResource Ui_FeedbackPrivacyCopy}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                        <Button Content="{DynamicResource Ui_SendFeatureFeedback}"
                                Click="SaveFeatureFeedback_Click"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0"
                                Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Border>

                <Border Grid.ColumnSpan="3"
                        Grid.Row="2"
                        Style="{StaticResource Panel}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ui_FeedbackFolder}" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                        <TextBlock Text="{DynamicResource Ui_FeedbackFolderHint}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding FeedbackDirectoryText}"
                                   Style="{StaticResource MutedText}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FeedbackDirectoryText}"
                                   Margin="0,0,0,10" />
                        <WrapPanel>
                            <Button Content="{DynamicResource Ui_OpenFeedbackFolder}"
                                    Click="OpenFeedbackDirectory_Click"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource Ui_OpenLatestFeedbackReport}"
                                    Click="OpenLatestFeedbackReport_Click"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource Ui_CopyLatestFeedbackReport}"
                                    Click="CopyLatestFeedbackReport_Click"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                        <TextBlock Text="{Binding FeedbackStatusText}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{DynamicResource Ui_FeedbackDeliveryHistory}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,14,0,8" />
                        <Border Visibility="{Binding HasFeedbackDeliveryHistory, Converter={StaticResource BoolToVisibilityConverter}}"
                                Style="{StaticResource EmptyState}">
                            <ItemsControl ItemsSource="{Binding FeedbackDeliveryHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="105" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimestampText}" Style="{StaticResource MutedText}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Kind}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Status}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Details}"
                                                       Style="{StaticResource MutedText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Details}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </TabItem>
</TabControl>
</UserControl>
