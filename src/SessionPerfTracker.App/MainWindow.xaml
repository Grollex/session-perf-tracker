                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Top">
                                    <Button Content="{DynamicResource Ui_Promote}"
                                            Click="PromoteRecommendation_Click"
                                            Style="{StaticResource PrimaryButton}"
                                            MinHeight="30"
                                            Padding="10,0"
                                            Margin="0,0,8,0" />
                                    <Button Content="{DynamicResource Ui_PromoteSelected}"
                                            Click="PromoteSelectedRecommendations_Click"
                                            Style="{StaticResource CompactButton}"
                                            Margin="0,0,8,0" />
                                    <Button Content="{DynamicResource Ui_IgnoreSelected}"
                                            Click="DenySelectedRecommendations_Click"
                                            Style="{StaticResource TertiaryButton}" />
                                </StackPanel>
                            </DockPanel>

                            <WrapPanel Grid.Row="2"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0">
                                <TextBlock Text="{DynamicResource Ui_TargetActions}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Margin="0,0,10,0" />
                                <Button Content="{DynamicResource Ui_Overview}"
                                        Click="SelectRecommendationTarget_Click"
                                        Style="{StaticResource CompactButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <Button Content="{DynamicResource Ui_ViewDetails}"
                                        Click="InspectRecommendationTarget_Click"
                                        Style="{StaticResource CompactButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <Button Content="{DynamicResource Ui_MarkSuspicious}"
                                        Click="MarkRecommendationSuspicious_Click"
                                        Style="{StaticResource CompactButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <ComboBox ItemsSource="{Binding ProcessBanDurationOptions}"
                                          SelectedItem="{Binding SelectedProcessBanDurationOption}"
                                          DisplayMemberPath="Label"
                                          Width="112"
                                          MinHeight="28"
                                          Margin="0,0,8,6" />
                                <Button Content="{DynamicResource Ui_Ban}"
                                        Click="BanRecommendationTarget_Click"
                                        Style="{StaticResource DangerButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <Button Content="{DynamicResource Ui_BanKill}"
                                        Click="BanAndKillRecommendationTarget_Click"
                                        Style="{StaticResource DangerButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                            </WrapPanel>

                            <ListView x:Name="ProfileRecommendationsList"
                                      Grid.Row="4"
                                      ItemsSource="{Binding ProfileRecommendations}"
                                      SelectedItem="{Binding SelectedProfileRecommendation}"
                                      SelectionMode="Extended"
                                      Background="#11171C"
                                      BorderBrush="{StaticResource BorderBrushSoft}"
                                      Foreground="{StaticResource TextBrush}"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource Ui_Exe}" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                        <GridViewColumn Header="{DynamicResource Ui_CurrentProfile}" Width="190">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding CurrentProfileText}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource Ui_Suggested}" Width="130" DisplayMemberBinding="{Binding SuggestedProfileText}" />
                                        <GridViewColumn Header="{DynamicResource Ui_Warnings}" Width="80" DisplayMemberBinding="{Binding WarningCountText}" />
                                        <GridViewColumn Header="{DynamicResource Ui_Reason}" Width="210">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Reason}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource Ui_FirstSeen}" Width="140" DisplayMemberBinding="{Binding FirstSeenText}" />
                                        <GridViewColumn Header="{DynamicResource Ui_LastSeen}" Width="140" DisplayMemberBinding="{Binding LastSeenText}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock Grid.Row="6"
                                       Text="{Binding ProfileRecommendationStatusText}"
                                       Style="{StaticResource MutedText}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui_DeniedIgnored}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{DynamicResource Ui_IgnoredHint}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="{DynamicResource Ui_RemoveDeny}"
                                        Click="RemoveRecommendationDeny_Click"
                                        Style="{StaticResource CompactButton}"
                                        VerticalAlignment="Top" />
                            </DockPanel>

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding DeniedProfileRecommendations}"
                                     SelectedItem="{Binding SelectedDeniedProfileRecommendation}"
                                     DisplayMemberPath="DisplayText"
                                     MinHeight="86"
                                     MaxHeight="180"
                                     Background="#11171C"
                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                     Foreground="{StaticResource TextBrush}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
                    </TabItem>

                    <TabItem Header="{DynamicResource Ui_Suspicious}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Panel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Ui_SuspiciousWatchlistTitle}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{DynamicResource Ui_SuspiciousHint}"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,4,0,0" />
