                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,3">
                                                <Border DockPanel.Dock="Right"
                                                        Padding="6,1"
                                                        CornerRadius="6"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#142A1D" />
                                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                                    <Setter Property="Background" Value="#2A2512" />
                                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                                    <Setter Property="Background" Value="#2A1F14" />
                                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                                    <Setter Property="Background" Value="#2B1719" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                                </Border>
                                                <TextBlock Text="{Binding TopRamText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{DynamicResource Ui_TopDisk}" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding TopDiskOffenders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,3">
                                                <Border DockPanel.Dock="Right"
                                                        Padding="6,1"
                                                        CornerRadius="6"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#142A1D" />
                                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                                    <Setter Property="Background" Value="#2A2512" />
                                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                                    <Setter Property="Background" Value="#2A1F14" />
                                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                                    <Setter Property="Background" Value="#2B1719" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                                </Border>
                                                <TextBlock Text="{Binding TopDiskText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox Text="{Binding GlobalWatchFilterText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="32" />
                            <TextBlock Text="{DynamicResource Ui_SearchProcessName}"
                                       IsHitTestVisible="False"
                                       Foreground="{StaticResource PlaceholderBrush}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GlobalWatchFilterText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal">
                            <CheckBox Content="{DynamicResource Ui_OnlyOverLimit}"
                                      IsChecked="{Binding GlobalWatchOnlyOverLimit}"
                                      Margin="0,0,18,0" />
                            <CheckBox Content="{DynamicResource Ui_OnlyCritical}"
                                      IsChecked="{Binding GlobalWatchOnlyCritical}"
                                      Margin="0,0,18,0" />
                            <CheckBox Content="{DynamicResource Ui_OnlyNearLimit}"
                                      IsChecked="{Binding GlobalWatchOnlyNearLimit}"
                                      Margin="0,0,18,0" />
                            <CheckBox Content="{DynamicResource Ui_OnlyUnassigned}"
                                      IsChecked="{Binding GlobalWatchOnlyUnassigned}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Panel}">
                            <Grid>
                                <ListView ItemsSource="{Binding GlobalWatchProcesses}"
                                          SelectedItem="{Binding SelectedGlobalProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="SelectionKey"
                                          IsSynchronizedWithCurrentItem="False"
                                          Background="#11171C"
                                          BorderBrush="{StaticResource BorderBrushSoft}"
                                          Foreground="{StaticResource TextBrush}"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="250">
                                                <GridViewColumn.Header>
                                                    <Button x:Name="GlobalWatchProcessHeaderButton"
                                                            Content="{DynamicResource Ui_ApplicationProcess}"
                                                            Click="SortGlobalWatchProcess_Click"
                                                            Style="{StaticResource TableHeaderSortButton}" />
                                                </GridViewColumn.Header>
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Width="90" DisplayMemberBinding="{Binding PidOrCountText}">
                                                <GridViewColumn.Header>
                                                    <Button x:Name="GlobalWatchPidHeaderButton"
                                                            Content="{DynamicResource Ui_PidOrCount}"
                                                            Click="SortGlobalWatchPid_Click"
                                                            Style="{StaticResource TableHeaderSortButton}" />
                                                </GridViewColumn.Header>
                                            </GridViewColumn>
                                            <GridViewColumn Width="78" DisplayMemberBinding="{Binding CpuText}">
                                                <GridViewColumn.Header>
                                                    <Button x:Name="GlobalWatchCpuHeaderButton"
                                                            Content="{DynamicResource Ui_CPU}"
                                                            Click="SortGlobalWatchCpu_Click"
                                                            Style="{StaticResource TableHeaderSortButton}" />
                                                </GridViewColumn.Header>
                                            </GridViewColumn>
                                            <GridViewColumn Width="110" DisplayMemberBinding="{Binding MemoryText}">
                                                <GridViewColumn.Header>
                                                    <Button x:Name="GlobalWatchRamHeaderButton"
                                                            Content="{DynamicResource Ui_RAM}"
                                                            Click="SortGlobalWatchRam_Click"
                                                            Style="{StaticResource TableHeaderSortButton}" />
                                                </GridViewColumn.Header>
                                            </GridViewColumn>
                                            <GridViewColumn Width="110" DisplayMemberBinding="{Binding DiskTotalText}">
                                                <GridViewColumn.Header>
                                                    <Button x:Name="GlobalWatchDiskHeaderButton"
                                                            Content="{DynamicResource Ui_Disk}"
                                                            Click="SortGlobalWatchDisk_Click"
                                                            Style="{StaticResource TableHeaderSortButton}" />
                                                </GridViewColumn.Header>
                                            </GridViewColumn>
                                            <GridViewColumn Width="104">
                                                <GridViewColumn.Header>
                                                    <Button x:Name="GlobalWatchProfileHeaderButton"
                                                            Content="{DynamicResource Ui_Profile}"
                                                            Click="SortGlobalWatchProfile_Click"
                                                            Style="{StaticResource TableHeaderSortButton}" />
                                                </GridViewColumn.Header>
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="7,2"
                                                                CornerRadius="7"
                                                                Background="#1B2630"
                                                                BorderBrush="#34566A"
                                                                BorderThickness="1">
                                                            <TextBlock Text="{Binding ProfileBadgeText}"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Width="92">
                                                <GridViewColumn.Header>
                                                    <Button x:Name="GlobalWatchHealthHeaderButton"
                                                            Content="{DynamicResource Ui_Health}"
                                                            Click="SortGlobalWatchHealth_Click"
                                                            Style="{StaticResource TableHeaderSortButton}" />
                                                </GridViewColumn.Header>
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="7,2"
                                                                CornerRadius="7"
                                                                BorderThickness="1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#142A1D" />
                                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                                            <Setter Property="Background" Value="#2A2512" />
                                                                            <Setter Property="BorderBrush" Value="#A88423" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                                            <Setter Property="Background" Value="#2A1F14" />
                                                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                                            <Setter Property="Background" Value="#2B1719" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding HealthBadgeText}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center" />
                                                        </Border>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <Border Padding="18"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasGlobalWatchRows}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding GlobalWatchEmptyStateText}"
                                               Style="{StaticResource MutedText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Panel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedGlobalProcessPanelTitle}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12" />
