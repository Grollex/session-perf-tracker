                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Top">
                                            <Button Content="{DynamicResource Ui_ViewDetails}"
                                                    Click="InspectSuspiciousWatchItem_Click"
                                                    Style="{StaticResource CompactButton}"
                                                    Margin="0,0,8,0" />
                                            <Button Content="{DynamicResource Ui_RemoveSelected}"
                                                    Click="RemoveSelectedSuspiciousWatchItem_Click"
                                                    Style="{StaticResource CompactButton}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <ListView Grid.Row="2"
                                              ItemsSource="{Binding SuspiciousWatchItems}"
                                              SelectedItem="{Binding SelectedSuspiciousWatchItem}"
                                              Background="#11171C"
                                              BorderBrush="{StaticResource BorderBrushSoft}"
                                              Foreground="{StaticResource TextBrush}"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasSuspiciousWatchItems, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="{DynamicResource Ui_Exe}" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Product}" Width="190">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ProductText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ProductText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="{DynamicResource Ui_Company}" Width="170">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding CompanyText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CompanyText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="{DynamicResource Ui_Signer}" Width="90" DisplayMemberBinding="{Binding SignerText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Marked}" Width="145" DisplayMemberBinding="{Binding MarkedAtText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Path}" Width="300">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding PathText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PathText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>

                                    <Border Grid.Row="2"
                                            Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
