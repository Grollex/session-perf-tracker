                                                            <TextBlock Text="{Binding CompanyText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CompanyText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="{DynamicResource Ui_Signer}" Width="110" DisplayMemberBinding="{Binding SignerText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Path}" Width="360">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding PathText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PathText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
