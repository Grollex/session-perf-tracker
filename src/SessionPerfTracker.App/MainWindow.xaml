                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSuspiciousWatchItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{DynamicResource Ui_NoSuspiciousItems}"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Row="4"
                                               Text="{Binding SuspiciousWatchStatusText}"
                                               Style="{StaticResource MutedText}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource Panel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{DynamicResource Ui_LaunchHistory}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <ListView Grid.Row="2"
                                              ItemsSource="{Binding SuspiciousLaunchEntries}"
