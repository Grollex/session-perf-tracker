                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="42"
                                               ToolTip="{Binding SelectedGlobalProcessTitle}" />
                                    <TextBlock Text="{Binding SelectedGlobalProcessHint}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,14" />

                                    <TextBlock Text="{DynamicResource Ui_Identity}"
                                               Style="{StaticResource MutedText}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{DynamicResource Ui_Product}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SelectedGlobalProcessProductText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding SelectedGlobalProcessProductText}" />
                                        <TextBlock Grid.Row="2" Text="{DynamicResource Ui_Exe}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGlobalProcessExeText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="4" Text="{DynamicResource Ui_Path}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="4"
                                                   Grid.Column="1"
                                                   Text="{Binding SelectedGlobalProcessPathText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding SelectedGlobalProcessPathText}" />
                                        <TextBlock Grid.Row="6" Text="{DynamicResource Ui_Description}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="6"
                                                   Grid.Column="1"
                                                   Text="{Binding SelectedGlobalProcessDescriptionText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding SelectedGlobalProcessDescriptionText}" />
                                        <TextBlock Grid.Row="8" Text="{DynamicResource Ui_Company}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedGlobalProcessCompanyText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="10" Text="{DynamicResource Ui_Signer}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding SelectedGlobalProcessSignerText}" />
                                        <TextBlock Grid.Row="12" Text="{DynamicResource Ui_Parent}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SelectedGlobalProcessParentText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="14" Text="{DynamicResource Ui_Tree}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding SelectedGlobalProcessDescendantsText}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="16" Text="{DynamicResource Ui_CPU}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding SelectedGlobalProcessCpuText}" />
                                        <TextBlock Grid.Row="18" Text="{DynamicResource Ui_RAM}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="18" Grid.Column="1" Text="{Binding SelectedGlobalProcessRamText}" />
                                        <TextBlock Grid.Row="20" Text="{DynamicResource Ui_DiskReadWrite}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="20" Grid.Column="1" Text="{Binding SelectedGlobalProcessDiskText}" />
                                        <TextBlock Grid.Row="22" Text="{DynamicResource Ui_Profile}" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="22" Grid.Column="1" Text="{Binding SelectedGlobalProcessProfileText}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="24" Text="{DynamicResource Ui_Health}" Style="{StaticResource MutedText}" />
                                        <Border Grid.Row="24"
                                                Grid.Column="1"
                                                Padding="7,2"
                                                CornerRadius="7"
                                                HorizontalAlignment="Left"
                                                BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#142A1D" />
                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Near">
                                                            <Setter Property="Background" Value="#2A2512" />
                                                            <Setter Property="BorderBrush" Value="#A88423" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Over">
                                                            <Setter Property="Background" Value="#2A1F14" />
                                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Critical">
                                                            <Setter Property="Background" Value="#2B1719" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SelectedGlobalProcessHealthText}" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Grid.Row="26" Text="{DynamicResource Ui_Reason}" Style="{StaticResource MutedText}" />
