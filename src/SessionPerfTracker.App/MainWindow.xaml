                                                        Click="BanAndKillGlobalProcess_Click"
                                                        IsEnabled="{Binding CanBanSelectedGlobalProcess}"
                                                        Style="{StaticResource DangerButton}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,10,0,0"
                                            Padding="9"
                                            CornerRadius="8"
                                            Background="#12191F"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Ui_SuspiciousWatchlist}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4" />
