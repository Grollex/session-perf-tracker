                                                        Click="MarkGlobalWatchSuspicious_Click"
                                                        IsEnabled="{Binding CanMarkSelectedGlobalProcessSuspicious}"
                                                        Style="{StaticResource CompactButton}"
                                                        Margin="0,0,6,0" />
