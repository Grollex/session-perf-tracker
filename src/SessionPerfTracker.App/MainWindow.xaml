<Window x:Class="SessionPerfTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppWindowTitle}"
        Icon="Assets/app.ico"
        Width="1420"
        Height="860"
        MinWidth="1220"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#101317"
        FontFamily="Segoe UI">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Description="{Binding AppWindowTitle}" />
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="PanelBrush" Color="#171C21" />
        <SolidColorBrush x:Key="PanelStrongBrush" Color="#20262D" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#303941" />
        <SolidColorBrush x:Key="TextBrush" Color="#EDF2F5" />
        <SolidColorBrush x:Key="MutedBrush" Color="#AAB6C0" />
        <SolidColorBrush x:Key="PlaceholderBrush" Color="#8695A1" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#74828D" />
        <SolidColorBrush x:Key="GoodBrush" Color="#3EE079" />
        <SolidColorBrush x:Key="WarnBrush" Color="#F4C542" />
        <SolidColorBrush x:Key="BadBrush" Color="#F05D5E" />
        <SolidColorBrush x:Key="ItemHoverBrush" Color="#202B34" />
        <SolidColorBrush x:Key="ItemSelectedBrush" Color="#26445A" />
        <SolidColorBrush x:Key="ItemSelectedBorderBrush" Color="#4FA0D8" />
        <SolidColorBrush x:Key="TabHoverBrush" Color="#1C252C" />
        <SolidColorBrush x:Key="TabSelectedBrush" Color="#223647" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SummaryTile" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#181F25" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DarkButtonBase" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#242A31" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2E3740" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#4A5B66" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D242B" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#181D22" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#252D34" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource DarkButtonBase}" />

        <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#23563A" />
            <Setter Property="BorderBrush" Value="#3DA76D" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TertiaryButton" TargetType="Button" BasedOn="{StaticResource CompactButton}">
            <Setter Property="Background" Value="#171C21" />
            <Setter Property="BorderBrush" Value="#2A333A" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2B1719" />
            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
        </Style>

        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ClickMode" Value="Press" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="#121920"
                                BorderBrush="#3A4650"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="30" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="9,0,4,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="#B6C3CC"
                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#18232B" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#587080" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#1B2A35" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#181D22" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#252D34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#121920" />
            <Setter Property="BorderBrush" Value="#3A4650" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource ComboBoxToggleButton}"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsEnabled="{TemplateBinding IsEnabled}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#10171D"
                                            BorderBrush="#4FA0D8"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="4">
                                        <ScrollViewer CanContentScroll="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemSelectedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#11171C" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="SelectionBrush" Value="#315E7A" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#4A5B66" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="#181D22" />
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#252D34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="4"
                                    Background="#11171C"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    Margin="0,1,8,0">
                                <Path x:Name="CheckMark"
                                      Data="M 3 8 L 6 11 L 12 4"
                                      Stroke="{StaticResource GoodBrush}"
                                      StrokeThickness="2"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4A5B66" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#142A1D" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#2E8D62" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="Box" Property="Background" Value="#181D22" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#252D34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollBarButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                CornerRadius="4"
                                Background="#42505B" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#5B6D79" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource DarkScrollBarButton}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource DarkScrollBarButton}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="IsDirectionReversed" TargetName="PART_Track" Value="False" />
                                <Setter Property="Height" TargetName="Root" Value="7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#101317" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#11171C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,12,8" />
            <Setter Property="MinWidth" Value="146" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabSelectedBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#11171C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,12" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabSelectedBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding Content}"
                                                  Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource ItemSelectedBrush}" />
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemSelectedBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Background" Value="#141A1F" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="6,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="TableHeaderSortButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderButtonBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18,14"
                Background="#14191E"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowSessionHeader, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="12"
                        CornerRadius="8"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#171C21" />
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                    <Setter Property="Background" Value="#13241B" />
                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                    <Setter Property="Background" Value="#28230F" />
                                    <Setter Property="BorderBrush" Value="#A88423" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                    <Setter Property="Background" Value="#2B1719" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="9,4"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        Margin="0,0,10,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#20262D" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                                    <Setter Property="Background" Value="#142A1D" />
                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                                    <Setter Property="Background" Value="#2A2512" />
                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                                    <Setter Property="Background" Value="#351B1E" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding LiveSessionStateText}"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                </Border>
                                <TextBlock Text="{Binding LiveSessionTargetText}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="720"
                                           ToolTip="{Binding LiveSessionTargetText}" />
                            </StackPanel>
                            <TextBlock Text="{Binding LiveSessionMetaText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding LiveSessionHintText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,4,0,0" />
                            <Border Visibility="{Binding HasLastCompletedSession, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    CornerRadius="8"
                                    Background="#11171C"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui_LastCompletedSession}" Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding LastCompletedSessionText}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LastCompletedSessionText}" />
                                    <TextBlock Text="{Binding LastCompletedSessionHint}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Margin="18,0,0,0">
                            <TextBlock Text="{Binding DurationText}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding StartedText}"
                                       Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="2" Columns="6">
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Duration}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding DurationText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Samples}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding SampleCountText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Tracked}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding TrackedProcessCountText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Events}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding EventCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource WarnBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Breaches}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding BreachCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BadBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Hangs}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding HangCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BadBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="12,7"
                Background="#12191F"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasCrossScreenMonitoringStrip, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Ui_OpenLive}"
                        Click="OpenLive_Click"
                        Style="{StaticResource CompactButton}" />
                <TextBlock Text="{Binding CrossScreenMonitoringStripText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="2"
                    TabStripPlacement="Left"
                    Padding="14,18,18,18"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="{DynamicResource Ui_Live}">
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <Grid Margin="16,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Padding="12"
                                CornerRadius="8"
                                BorderThickness="1"
                                Margin="0,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#171C21" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                            <Setter Property="Background" Value="#13241B" />
                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                            <Setter Property="Background" Value="#28230F" />
                                            <Setter Property="BorderBrush" Value="#A88423" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                            <Setter Property="Background" Value="#2B1719" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Padding="8,3"
                                                CornerRadius="8"
                                                BorderThickness="1"
                                                Margin="0,0,10,0"
                                                Background="#20262D"
                                                BorderBrush="{StaticResource BorderBrushSoft}">
                                            <TextBlock Text="{Binding LiveSessionStateText}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                        </Border>
                                        <TextBlock Text="{Binding LiveSessionTargetText}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="680"
                                                   ToolTip="{Binding LiveSessionTargetText}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding LiveSessionMetaText}"
                                               Style="{StaticResource MutedText}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LiveSessionMetaText}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding LiveSessionHintText}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <UniformGrid Grid.Column="1"
                                             Columns="4"
                                             Margin="18,0,0,0"
                                             VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{DynamicResource Ui_Version}" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding AppVersionBadgeText}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{DynamicResource Ui_Duration}" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding DurationText}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{DynamicResource Ui_Samples}" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding SampleCountText}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_Events}" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding EventCountText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource WarnBrush}" />
                                    </StackPanel>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,14,0">
                            <StackPanel>
                                <Border Visibility="{Binding HasLiveWarning, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,12"
                                        Padding="10"
                                        CornerRadius="8"
                                        Background="#2B1719"
                                        BorderBrush="{StaticResource BadBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding LiveWarningText}"
                                               Foreground="{StaticResource BadBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="{DynamicResource Ui_Target}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,6" />
                                <TextBlock Text="{DynamicResource Ui_Source}" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding TargetModes}"
                                          SelectedItem="{Binding SelectedTargetMode}" />
                                <Border Margin="0,10,0,0"
                                        Padding="10"
                                        CornerRadius="8"
                                        Background="#12191F"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TargetReadinessText}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="40"
                                                   ToolTip="{Binding TargetReadinessText}" />
                                        <TextBlock Text="{Binding ActiveThresholdSourceText}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="40"
                                                   ToolTip="{Binding ActiveThresholdSourceText}" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Visibility="{Binding IsRunningProcessMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel Margin="0,12,0,0">
                                        <TextBlock Text="{DynamicResource Ui_RunningProcess}" Style="{StaticResource MutedText}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="{DynamicResource Ui_Refresh}"
                                                Click="RefreshProcesses_Click"
                                                MinHeight="26"
                                                Padding="8,0" />
                                    </DockPanel>
                                    <Grid Margin="0,6,0,0">
                                        <TextBox Text="{Binding ProcessFilterText, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="32" />
                                        <TextBlock Text="{DynamicResource Ui_SearchProcesses}"
                                                   IsHitTestVisible="False"
                                                   Foreground="{StaticResource PlaceholderBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProcessFilterText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <ComboBox ItemsSource="{Binding RunningTargets}"
                                              SelectedItem="{Binding SelectedRunningTarget}"
                                              DisplayMemberPath="DisplayName" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsAssignedAppsMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel Margin="0,12,0,0">
                                        <TextBlock Text="{DynamicResource Ui_AssignedAppsProfiles}" Style="{StaticResource MutedText}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="{DynamicResource Ui_Refresh}"
                                                Click="RefreshProcesses_Click"
                                                MinHeight="26"
                                                Padding="8,0" />
                                    </DockPanel>
                                    <ComboBox ItemsSource="{Binding AssignedTargets}"
                                              SelectedItem="{Binding SelectedAssignedTarget}"
                                              DisplayMemberPath="DisplayText" />
                                    <TextBlock Text="{DynamicResource Ui_AssignedAppsHint}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,6,0,0" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsExecutableMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{DynamicResource Ui_ManualExecutableLaunch}" Style="{StaticResource MutedText}" Margin="0,14,0,0" />
                                    <Button Content="{DynamicResource Ui_ChooseExe}"
                                            Click="BrowseExecutable_Click"
                                            Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding SelectedExecutableDisplay}"
                                               Style="{StaticResource MutedText}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                                <TextBlock Text="{DynamicResource Ui_Session}" FontSize="13" FontWeight="SemiBold" Margin="0,18,0,6" />
                                <TextBlock Text="{DynamicResource Ui_SessionProfile}" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding SessionProfileOptions}"
                                          SelectedItem="{Binding SelectedSessionProfileOption}"
                                          DisplayMemberPath="DisplayName" />
                                <TextBlock Text="{DynamicResource Ui_Sampling}" Style="{StaticResource MutedText}" Margin="0,12,0,0" />
                                <ComboBox ItemsSource="{Binding SamplingOptions}"
                                          SelectedItem="{Binding SelectedSamplingOption}"
                                          DisplayMemberPath="Label" />
                                <CheckBox Content="{DynamicResource Ui_IncludeChildProcesses}" IsChecked="{Binding IncludeChildProcesses}" />
                                <CheckBox Content="{DynamicResource Ui_LiveMonitor}" IsChecked="{Binding IsLiveMonitorEnabled}" />
                                <TextBlock Text="{Binding RecordingStatusText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,10,0,0" />
                                <UniformGrid Columns="2" Margin="0,12,0,0">
                                    <Button Content="{DynamicResource Ui_Start}"
                                            Click="StartRecording_Click"
                                            IsEnabled="{Binding CanStart}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,0" />
                                    <Button Content="{DynamicResource Ui_Stop}"
                                            Click="StopRecording_Click"
                                            Style="{StaticResource DangerButton}"
                                            IsEnabled="{Binding CanStop}" />
                                </UniformGrid>

                                <TextBlock Text="{DynamicResource Ui_Assignments}" FontSize="13" FontWeight="SemiBold" Margin="0,18,0,6" />
                                <TextBlock Text="{DynamicResource Ui_AssignCurrentTarget}" Style="{StaticResource MutedText}" />
                                <DockPanel Margin="0,6,0,0">
                                    <Button DockPanel.Dock="Right"
                                            Content="{DynamicResource Ui_Assign}"
                                            Click="AssignCurrentTargetProfile_Click"
                                            MinHeight="30"
                                            Padding="10,0"
                                            Margin="8,0,0,0" />
                                    <ComboBox ItemsSource="{Binding ThresholdProfiles}"
                                              SelectedItem="{Binding SelectedLiveAssignmentProfile}"
                                              DisplayMemberPath="DisplayName" />
                                </DockPanel>
                                <TextBlock Text="{Binding LiveAssignmentStatusText}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="42"
                                           ToolTip="{Binding LiveAssignmentStatusText}"
                                           Margin="0,6,0,0" />

                                <Expander Header="{DynamicResource Ui_Diagnostics}"
                                          Foreground="{StaticResource TextBrush}"
                                          Margin="0,16,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <Button Content="{DynamicResource Ui_RamDiagnosticSnapshot}"
                                                Click="CaptureRamDiagnostic_Click" />
                                        <TextBox Text="{Binding RamDiagnosticText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 MinHeight="72"
                                                 MaxHeight="120"
                                                 Margin="0,8,0,0" />
                                        <Button Content="{DynamicResource Ui_SystemContextSnapshot}"
                                                Click="CaptureSystemContext_Click"
                                                Margin="0,12,0,0" />
                                        <TextBox Text="{Binding SystemContextText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 MinHeight="72"
                                                 MaxHeight="120"
                                                 Margin="0,8,0,0" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2" Grid.Column="1">
                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14" LastChildFill="False">
                                    <TextBlock Text="{Binding LiveSnapshotTitle}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding LiveSnapshotStatusText}" Style="{StaticResource MutedText}" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding CurrentMetrics}"
                                              Visibility="{Binding HasActiveLiveMetrics, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,10,10"
                                                    Padding="14"
                                                    CornerRadius="8"
                                                    Background="{StaticResource PanelStrongBrush}"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding LiveSnapshotScopeText}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,10" />
                                <Border Visibility="{Binding ShowLiveSnapshotEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Padding="12"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LiveSnapshotEmptyText}"
                                                   Style="{StaticResource MutedText}" />
                                        <UniformGrid Columns="2" Margin="0,10,0,0">
                                            <Border Style="{StaticResource SummaryTile}">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Ui_Target}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding LiveConfigTargetText}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding LiveConfigTargetText}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource SummaryTile}" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Ui_Collectors}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding LiveConfigCollectorsText}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource SummaryTile}">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Ui_Profile}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding ActiveThresholdSourceText}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource SummaryTile}" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Ui_Capture}" Style="{StaticResource MutedText}" />
                                                    <TextBlock FontWeight="SemiBold">
                                                        <Run Text="{Binding LiveConfigSamplingText, Mode=OneWay}" />
                                                        <Run Text=" / " />
                                                        <Run Text="{Binding LiveConfigChildScopeText, Mode=OneWay}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding LiveConfigMonitorText}" Style="{StaticResource MutedText}" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="{DynamicResource Ui_Events}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding EventCountText}" Style="{StaticResource MutedText}" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding VisibleEvents}"
                                              Visibility="{Binding HasLiveEvents, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                        <TextBlock Style="{StaticResource MutedText}">
                                                            <Run Text="{Binding Kind, Mode=OneWay}" />
                                                            <Run Text=" / " />
                                                            <Run Text="{Binding Metric, Mode=OneWay}" />
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" />
                                                        <TextBlock Text="{Binding ContextSummaryText}"
                                                                   Style="{StaticResource MutedText}"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding ObservedText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Visibility="{Binding ShowLiveEventEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Padding="16"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding LiveEventEmptyText}"
                                               Style="{StaticResource MutedText}" />
                                </Border>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_GlobalWatch}">
                <TabControl Margin="16,0,0,0"
                            TabStripPlacement="Top"
                            Padding="0"
                            SelectedIndex="{Binding SelectedGlobalWatchSectionIndex, Mode=TwoWay}"
                            ItemContainerStyle="{StaticResource SubTabItem}">
                    <TabItem Header="{DynamicResource Ui_Overview}">
                        <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
