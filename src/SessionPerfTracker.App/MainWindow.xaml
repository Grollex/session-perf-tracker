<Window x:Class="SessionPerfTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SessionPerfTracker.App.Views"
        mc:Ignorable="d"
        Title="{Binding AppWindowTitle}"
        Icon="Assets/app.ico"
        Width="1420"
        Height="860"
        MinWidth="1220"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#101317"
        FontFamily="Segoe UI">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Description="{Binding AppWindowTitle}" />
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <ResourceDictionary Source="Themes/MainWindowResources.xaml" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12,8"
                Background="#12191F"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Ui_ReportBugQuick}"
                        Click="ReportBug_Click"
                        Style="{StaticResource CompactButton}" />
                <TextBlock Text="{Binding AppWindowTitle}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Padding="14,10"
                Background="#1B2118"
                BorderBrush="#3E6B3A"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowTrustExplainer, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Ui_TrustExplainerDismiss}"
                        Click="DismissTrustExplainer_Click"
                        Style="{StaticResource CompactButton}"
                        Margin="12,0,0,0" />
                <StackPanel>
                    <TextBlock Text="{DynamicResource Ui_TrustExplainerTitle}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,3" />
                    <TextBlock Text="{DynamicResource Ui_TrustExplainerBody}"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="12,7"
                Background="#12191F"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasCrossScreenMonitoringStrip, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Ui_OpenLive}"
                        Click="OpenLive_Click"
                        Style="{StaticResource CompactButton}" />
                <TextBlock Text="{Binding CrossScreenMonitoringStripText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="3"
                    TabStripPlacement="Left"
                    Padding="14,18,18,18"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="{DynamicResource Ui_Live}">
                <views:LiveMonitoringView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_GlobalWatch}">
                <views:GlobalWatchView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Sessions}">
                <views:SessionsView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Details}">
                <views:SessionDetailsView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Compare}">
                <views:CompareView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Settings}">
                <views:SettingsView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>




