                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ParentText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ParentText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
