<Window x:Class="SessionPerfTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SessionPerfTracker.App.Views"
        mc:Ignorable="d"
        Title="{Binding AppWindowTitle}"
        Icon="Assets/app.ico"
        Width="1420"
        Height="860"
        MinWidth="1220"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#101317"
        FontFamily="Segoe UI">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Description="{Binding AppWindowTitle}" />
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <ResourceDictionary Source="Themes/MainWindowResources.xaml" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18,14"
                Background="#14191E"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowSessionHeader, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="12"
                        CornerRadius="8"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#171C21" />
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                    <Setter Property="Background" Value="#13241B" />
                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                    <Setter Property="Background" Value="#28230F" />
                                    <Setter Property="BorderBrush" Value="#A88423" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                    <Setter Property="Background" Value="#2B1719" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="9,4"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        Margin="0,0,10,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#20262D" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                                    <Setter Property="Background" Value="#142A1D" />
                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                                    <Setter Property="Background" Value="#2A2512" />
                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                                    <Setter Property="Background" Value="#351B1E" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding LiveSessionStateText}"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                </Border>
                                <TextBlock Text="{Binding LiveSessionTargetText}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="720"
                                           ToolTip="{Binding LiveSessionTargetText}" />
                            </StackPanel>
                            <TextBlock Text="{Binding LiveSessionMetaText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding LiveSessionHintText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,4,0,0" />
                            <Border Visibility="{Binding HasLastCompletedSession, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    CornerRadius="8"
                                    Background="#11171C"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui_LastCompletedSession}" Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding LastCompletedSessionText}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LastCompletedSessionText}" />
                                    <TextBlock Text="{Binding LastCompletedSessionHint}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Margin="18,0,0,0">
                            <TextBlock Text="{Binding DurationText}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding StartedText}"
                                       Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="2" Columns="6">
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Duration}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding DurationText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Samples}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding SampleCountText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Tracked}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding TrackedProcessCountText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Events}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding EventCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource WarnBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Breaches}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding BreachCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BadBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui_Hangs}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding HangCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BadBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="12,7"
                Background="#12191F"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasCrossScreenMonitoringStrip, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Ui_OpenLive}"
                        Click="OpenLive_Click"
                        Style="{StaticResource CompactButton}" />
                <TextBlock Text="{Binding CrossScreenMonitoringStripText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="2"
                    TabStripPlacement="Left"
                    Padding="14,18,18,18"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="{DynamicResource Ui_Live}">
                <views:LiveMonitoringView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_GlobalWatch}">
                <views:GlobalWatchView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Sessions}">
                <views:SessionsView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Details}">
                <views:SessionDetailsView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Compare}">
                <views:CompareView />
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Settings}">
                <views:SettingsView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>




