                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="{DynamicResource Ui_Signer}" Width="90" DisplayMemberBinding="{Binding SignerText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Parent}" Width="170">
