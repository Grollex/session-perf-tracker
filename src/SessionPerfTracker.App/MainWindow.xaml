                                    </ListView>

                                    <Border Grid.Row="2"
                                            Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProcessBans}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{DynamicResource Ui_NoBans}"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Row="4"
                                               Text="{Binding ProcessBanStatusText}"
                                               Style="{StaticResource MutedText}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource Panel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_BanHistory}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{DynamicResource Ui_BanHistoryHint}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <ListView Grid.Row="2"
                                              ItemsSource="{Binding ProcessBanEvents}"
                                              Background="#11171C"
                                              BorderBrush="{StaticResource BorderBrushSoft}"
                                              Foreground="{StaticResource TextBrush}"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasProcessBanEvents, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="{DynamicResource Ui_Time}" Width="145" DisplayMemberBinding="{Binding TimestampText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Action}" Width="120" DisplayMemberBinding="{Binding ActionText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Exe}" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Duration}" Width="100" DisplayMemberBinding="{Binding DurationText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Terminated}" Width="85" DisplayMemberBinding="{Binding TerminatedText}" />
                                                <GridViewColumn Header="{DynamicResource Ui_Process}" Width="190">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ProcessText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ProcessText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="{DynamicResource Ui_Details}" Width="360">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DetailsText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding DetailsText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Border Grid.Row="2"
                                            Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProcessBanEvents}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{DynamicResource Ui_NoBanEvents}"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Sessions}">
                <Grid Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="{DynamicResource Ui_SavedSessions}" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="{DynamicResource Ui_OpenDetails}"
                                            Click="OpenSessionDetails_Click"
                                            MinHeight="26"
                                            Padding="8,0"
                                            Margin="0,0,8,0" />
                                    <Button Content="{DynamicResource Ui_Refresh}"
                                            Click="RefreshSessions_Click"
                                            MinHeight="26"
                                            Padding="8,0" />
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                <Grid>
                                    <TextBox Text="{Binding SessionSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Text="{DynamicResource Ui_SearchSessions}"
                                               IsHitTestVisible="False"
                                               Foreground="{StaticResource PlaceholderBrush}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SessionSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock Text="{DynamicResource Ui_Profile}"
                                               Style="{StaticResource MutedText}"
                                               VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{Binding SessionProfileFilters}"
                                              SelectedItem="{Binding SelectedSessionProfileFilter}"
                                              DisplayMemberPath="Label"
                                              Margin="12,0,0,0" />
                                </DockPanel>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Sessions}"
                                     Grid.Row="2"
                                     SelectedItem="{Binding SelectedSession}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                            <TextBlock Style="{StaticResource MutedText}">
                                                <Run Text="{Binding StartedText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding DurationText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding ChildTrackingText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding SamplingText, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding QualityHint}" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding StabilityText}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Panel}">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="{DynamicResource Ui_MetricSummary}" FontSize="16" FontWeight="SemiBold" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="{DynamicResource Ui_ExportHtml}"
                                                Click="ExportSelectedSessionHtml_Click"
                                                MinHeight="28"
                                                Padding="10,0"
                                                Margin="0,0,8,0" />
                                        <Button Content="{DynamicResource Ui_ExportCsv}"
                                                Click="ExportSelectedSessionCsv_Click"
                                                MinHeight="28"
                                                Padding="10,0" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="{Binding ExportStatusText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,12" />
                                <Border Padding="12"
                                        Margin="0,0,0,12"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedSession.StabilityText}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SelectedSession.StabilityReason}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding SelectedSession.StartupText}" />
                                            <TextBlock Text="{DynamicResource Ui_BestEffortReady}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding SelectedSession.ExitText}" />
                                            <TextBlock Text="{DynamicResource Ui_BasedRecordedEvents}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding SelectedMetricSummaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding MinLabel}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding AvgLabel}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding MaxLabel}" />
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="{Binding SpikeLabel}" />
                                                        <TextBlock Text="{Binding BreachLabel}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Padding="12"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_NotCollected}" Style="{StaticResource MutedText}" />
                                        <ItemsControl ItemsSource="{Binding UnsupportedMetricNotices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Details}">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,0,0,0">
                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SessionDetailTitle}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SessionDetailSubtitle}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="{DynamicResource Ui_BackToSessions}"
                                            Click="BackToSessions_Click"
                                            Style="{StaticResource CompactButton}" />
                                </DockPanel>

                                <TextBlock Text="{DynamicResource Ui_SessionDetailsHint}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSessionDetails}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl ItemsSource="{Binding SessionDetailFacts}"
                                              Visibility="{Binding HasSessionDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,10,10"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding Value}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="{DynamicResource Ui_MetricOverview}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{DynamicResource Ui_RecordedMetricsOnly}"
                                               Style="{StaticResource MutedText}" />
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding SessionDetailMetricSummaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.3*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding MinLabel}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding AvgLabel}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding MaxLabel}" />
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="{Binding SpikeLabel}" />
                                                        <TextBlock Text="{Binding BreachLabel}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{DynamicResource Ui_NoMetricSummaries}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSessionDetailMetrics}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Border Padding="12"
                                        Margin="0,10,0,0"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_NotShownRecorded}" Style="{StaticResource MutedText}" />
                                        <ItemsControl ItemsSource="{Binding SessionDetailUnsupportedMetricNotices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="{DynamicResource Ui_TimelineEventReview}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{DynamicResource Ui_Chronological}"
                                               Style="{StaticResource MutedText}" />
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding SessionDetailEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,10"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                            <TextBlock Style="{StaticResource MutedText}">
                                                                <Run Text="{Binding ElapsedText, Mode=OneWay}" />
                                                                <Run Text=" / " />
                                                                <Run Text="{Binding TimestampText, Mode=OneWay}" />
                                                                <Run Text=" / " />
                                                                <Run Text="{Binding Metric, Mode=OneWay}" />
                                                                <Run Text=" / " />
                                                                <Run Text="{Binding Kind, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding ObservedText}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding ThresholdText}"
                                                                       Style="{StaticResource MutedText}"
                                                                       HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border Margin="0,8,0,0"
                                                            Padding="8"
                                                            CornerRadius="6"
                                                            Background="#1B252D"
                                                            BorderBrush="#34566A"
                                                            BorderThickness="1"
                                                            Visibility="{Binding IsGrouped, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding GroupedText}" Style="{StaticResource MutedText}" />
                                                    </Border>

                                                    <TextBlock Text="{Binding Details}"
                                                               Style="{StaticResource MutedText}"
                                                               Margin="0,8,0,0" />

                                                    <Expander Header="{DynamicResource Ui_ContextAroundEvent}"
                                                              Foreground="{StaticResource TextBrush}"
                                                              Background="#11171C"
                                                              Margin="0,10,0,0"
                                                              Visibility="{Binding HasContext, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border Padding="10"
                                                                CornerRadius="8"
                                                                Background="#11171C"
                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding ContextCapturedText}" Style="{StaticResource MutedText}" />
                                                                <TextBlock Text="{Binding ContextNoteText}" Style="{StaticResource MutedText}" Margin="0,2,0,10" />

                                                                <TextBlock Text="{DynamicResource Ui_TopCpuNearby}" FontWeight="SemiBold" />
                                                                <ItemsControl ItemsSource="{Binding TopCpuContext}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding SummaryText}"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Text="{DynamicResource Ui_TopRamNearby}" FontWeight="SemiBold" Margin="0,10,0,0" />
                                                                <ItemsControl ItemsSource="{Binding TopRamContext}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding SummaryText}"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Text="{DynamicResource Ui_TopDiskNearby}" FontWeight="SemiBold" Margin="0,10,0,0" />
                                                                <ItemsControl ItemsSource="{Binding TopDiskContext}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding SummaryText}"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <StackPanel Margin="0,10,0,0"
                                                                            Visibility="{Binding HasNewProcessContext, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock Text="{DynamicResource Ui_NewProcessesNearby}" FontWeight="SemiBold" />
                                                                    <ItemsControl ItemsSource="{Binding NewProcessContext}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{DynamicResource Ui_NoDetectorEvents}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSessionDetailEvents}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Compare}">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,0,0,0">
                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui_Left}" Style="{StaticResource MutedText}" />
                                    <ComboBox ItemsSource="{Binding Sessions}"
                                              SelectedItem="{Binding CompareLeft}"
                                              DisplayMemberPath="CompareLabel" />
                                    <TextBlock Text="{Binding CompareLeft.StabilityText}" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{DynamicResource Ui_Right}" Style="{StaticResource MutedText}" />
                                    <ComboBox ItemsSource="{Binding Sessions}"
                                              SelectedItem="{Binding CompareRight}"
                                              DisplayMemberPath="CompareLabel" />
                                    <TextBlock Text="{Binding CompareRight.StabilityText}" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="{DynamicResource Ui_MetricDelta}" FontSize="16" FontWeight="SemiBold" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="{DynamicResource Ui_ExportHtml}"
                                                Click="ExportCurrentCompareHtml_Click"
                                                MinHeight="28"
                                                Padding="10,0"
                                                Margin="0,0,8,0" />
                                        <Button Content="{DynamicResource Ui_ExportCsv}"
                                                Click="ExportCurrentCompareCsv_Click"
                                                MinHeight="28"
                                                Padding="10,0" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="{Binding ExportStatusText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,12" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Ui_Metric}" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="1" Text="{DynamicResource Ui_LeftAvg}" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Ui_RightAvg}" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="3" Text="{DynamicResource Ui_Delta}" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="4" Text="{DynamicResource Ui_MaxDelta}" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="5" Text="{DynamicResource Ui_Better}" Style="{StaticResource MutedText}" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding ComparisonRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Metric}" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding LeftAvg}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding RightAvg}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Delta}" Foreground="{StaticResource WarnBrush}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding MaxDelta}" />
                                                    <TextBlock Grid.Column="5" Text="{Binding Winner}" Foreground="{StaticResource GoodBrush}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Padding="12"
                                        Margin="0,8,0,0"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_UnavailableMetrics}" Style="{StaticResource MutedText}" />
                                        <ItemsControl ItemsSource="{Binding UnavailableComparisonMetrics}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayText}" Style="{StaticResource MutedText}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Settings}">
                <TabControl Margin="16,0,0,0">
                    <TabItem Header="{DynamicResource Ui_Capture}">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_CollectorsCapture}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <TextBlock Text="{DynamicResource Ui_SamplingSettingsHint}" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{DynamicResource Ui_SamplingHint}" Style="{StaticResource MutedText}" Margin="0,4,0,12" />
                                        <UniformGrid Columns="2" Margin="0,0,0,12">
                                            <CheckBox Content="{DynamicResource Ui_CPU}" IsChecked="{Binding CaptureCpu}" />
                                            <CheckBox Content="{DynamicResource Ui_RAM}" IsChecked="{Binding CaptureRam}" />
                                            <CheckBox Content="{DynamicResource Ui_DiskRead}" IsChecked="{Binding CaptureDiskRead}" />
                                            <CheckBox Content="{DynamicResource Ui_DiskWrite}" IsChecked="{Binding CaptureDiskWrite}" />
                                        </UniformGrid>
                                        <TextBlock Text="{DynamicResource Ui_UnsupportedCollectorsHint}" Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                                        <Button Content="{DynamicResource Ui_SaveCaptureScope}"
                                                Click="SaveCaptureSettings_Click"
                                                HorizontalAlignment="Left" />
                                        <TextBlock Text="{Binding ThresholdSettingsStatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />

                                        <TextBlock Text="{DynamicResource Ui_AntiNoise}" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,12" />
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{DynamicResource Ui_StartupGrace}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding StartupGraceSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <TextBlock Grid.Column="3" Text="{DynamicResource Ui_Cooldown}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="4" Text="{Binding EventCooldownSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <TextBlock Grid.Row="2" Text="{DynamicResource Ui_Grouping}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding GroupingWindowSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{DynamicResource Ui_SnapshotSuppress}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding SnapshotSuppressionSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <Button Grid.Row="4" Grid.ColumnSpan="6" Content="{DynamicResource Ui_SaveAntiNoise}" Click="SaveAntiNoiseSettings_Click" HorizontalAlignment="Left" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_SelfMonitoring}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="{DynamicResource Ui_SelfProcess}" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding SelfMonitoringStatusText}" Style="{StaticResource MutedText}" />
                                        </DockPanel>
                                        <UniformGrid Columns="2" Margin="0,0,0,18">
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="{DynamicResource Ui_CpuNowAvgPeak}" Style="{StaticResource MutedText}" />
                                                <TextBlock>
                                                    <Run Text="{Binding SelfCurrentCpuText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfAvgCpuText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfPeakCpuText, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="{DynamicResource Ui_RamNowAvgPeak}" Style="{StaticResource MutedText}" />
                                                <TextBlock>
                                                    <Run Text="{Binding SelfCurrentRamText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfAvgRamText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfPeakRamText, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Ui_SelfDiskWrite}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfDiskWriteText}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Ui_Samples}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfSampleCountText}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="{DynamicResource Ui_OverheadBudget}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="{DynamicResource Ui_AvgCpuBudget}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfCpuBudgetStatusText}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="{DynamicResource Ui_PeakRamBudget}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfRamBudgetStatusText}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Ui_WritesBatched}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfWritesBudgetStatusText}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Ui_DeepSnapshots}" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfSnapshotsBudgetStatusText}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <Border Margin="0,18,0,0"
                                                Padding="12"
                                                CornerRadius="8"
                                                Background="#11171C"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Ui_AppBehavior}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <CheckBox Content="{DynamicResource Ui_KeepRunningBackground}"
                                                          IsChecked="{Binding MinimizeToTrayOnClose}" />
                                                <TextBlock Text="{DynamicResource Ui_AppBehaviorHint}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,6,0,10" />
                                                <Button Content="{DynamicResource Ui_SaveAppBehavior}"
                                                        Click="SaveAppBehaviorSettings_Click"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource CompactButton}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,12,0,0"
                                                Padding="12"
                                                CornerRadius="8"
                                                Background="#11171C"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Ui_Language}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                                          SelectedItem="{Binding SelectedLanguageOption}"
                                                          DisplayMemberPath="DisplayName"
                                                          MaxWidth="220"
                                                          HorizontalAlignment="Left" />
                                                <Button Content="{DynamicResource Ui_SaveLanguage}"
                                                        Click="SaveLanguageSettings_Click"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource CompactButton}"
                                                        Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding LanguageSettingsStatusText}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{DynamicResource Ui_Profiles}">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <Border Style="{StaticResource Panel}">
                                <StackPanel>
                                <TextBlock Text="{DynamicResource Ui_ThresholdProfiles}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                <TextBlock Text="{DynamicResource Ui_GlobalFallback}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Ui_CpuPercent}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding CpuThresholdPercentText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Column="3" Text="{DynamicResource Ui_RamMb}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="4"
                                             Text="{Binding RamThresholdMbText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="2" Text="{DynamicResource Ui_DiskReadRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding DiskReadThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{DynamicResource Ui_DiskWriteRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="4"
                                             Text="{Binding DiskWriteThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <Button Grid.Column="5"
                                            Grid.RowSpan="3"
                                            Content="{DynamicResource Ui_SaveFallback}"
                                            Click="SaveThresholdSettings_Click"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="14,0,0,0" />
                                </Grid>

                                <Grid Margin="0,0,0,18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Ui_SelectedProfile}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              Grid.ColumnSpan="2"
                                              ItemsSource="{Binding ThresholdProfiles}"
                                              SelectedItem="{Binding SelectedThresholdProfile}"
                                              DisplayMemberPath="DisplayName"
                                              Margin="0" />
                                    <Button Grid.Column="3"
                                            Content="{DynamicResource Ui_ResetSelected}"
                                            Click="ResetSelectedProfile_Click"
                                            HorizontalAlignment="Left" />
                                    <Button Grid.Column="4"
                                            Grid.ColumnSpan="2"
                                            Content="{DynamicResource Ui_ResetAllThresholds}"
                                            Click="ResetAllThresholdSettings_Click"
                                            HorizontalAlignment="Left" />

                                    <TextBlock Grid.Row="2" Text="{DynamicResource Ui_CpuPercent}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding ProfileCpuThresholdPercentText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{DynamicResource Ui_RamMb}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="4"
                                             Text="{Binding ProfileRamThresholdMbText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />

                                    <TextBlock Grid.Row="4" Text="{DynamicResource Ui_DiskReadRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             Text="{Binding ProfileDiskReadThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="{DynamicResource Ui_DiskWriteRate}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="4"
                                             Grid.Column="4"
                                             Text="{Binding ProfileDiskWriteThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <Button Grid.Row="4"
                                            Grid.Column="5"
                                            Content="{DynamicResource Ui_SaveProfile}"
                                            Click="SaveSelectedProfile_Click"
                                            HorizontalAlignment="Left"
                                            Margin="14,0,0,0" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Ui_AppAssignment}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding AssignmentExeNameText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding ThresholdProfiles}"
                                              SelectedItem="{Binding SelectedAssignmentProfile}"
                                              DisplayMemberPath="DisplayName"
                                              Margin="0" />
                                    <Button Grid.Column="4"
                                            Content="{DynamicResource Ui_Assign}"
                                            Click="SaveAppProfileAssignment_Click"
                                            HorizontalAlignment="Left"
                                            Margin="14,0,0,0" />
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ListBox ItemsSource="{Binding AppProfileAssignments}"
                                             SelectedItem="{Binding SelectedAppProfileAssignment}"
                                             DisplayMemberPath="DisplayText"
                                             MinHeight="72"
                                             MaxHeight="140"
                                             Background="#11171C"
                                             BorderBrush="{StaticResource BorderBrushSoft}"
                                             Foreground="{StaticResource TextBrush}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    <Button Grid.Column="1"
                                            Content="{DynamicResource Ui_RemoveAssignment}"
                                            Click="RemoveAppProfileAssignment_Click"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="14,0,0,0" />
                                </Grid>
                                <TextBlock Text="{Binding ThresholdSettingsStatusText}" Style="{StaticResource MutedText}" Margin="0,0,0,18" />

                            </StackPanel>
                        </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{DynamicResource Ui_Storage}">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_StorageRetention}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="{DynamicResource Ui_Retention}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <Button DockPanel.Dock="Right"
                                                    Content="{DynamicResource Ui_Save}"
                                                    Click="SaveRetentionSettings_Click"
                                                    MinHeight="30"
                                                    Padding="10,0"
                                                    Margin="8,0,0,0" />
                                            <ComboBox ItemsSource="{Binding RetentionOptions}"
                                                      SelectedItem="{Binding SelectedRetentionOption}"
                                                      DisplayMemberPath="Label"
                                                      Margin="12,0,0,0" />
                                        </DockPanel>
                                        <UniformGrid Columns="2" Margin="0,0,0,8">
                                            <Button Content="{DynamicResource Ui_DeleteAllSessions}" Click="DeleteAllSessions_Click" Margin="0,0,8,8" />
                                            <Button Content="{DynamicResource Ui_DeleteFilteredSessions}" Click="DeleteFilteredSessions_Click" Margin="0,0,0,8" />
                                            <Button Content="{DynamicResource Ui_DeleteOlder1}" Click="DeleteSessionsOlderThan1Day_Click" Margin="0,0,8,8" />
                                            <Button Content="{DynamicResource Ui_DeleteOlder7}" Click="DeleteSessionsOlderThan7Days_Click" Margin="0,0,0,8" />
                                            <Button Content="{DynamicResource Ui_DeleteOlder30}" Click="DeleteSessionsOlderThan30Days_Click" Margin="0,0,8,0" />
                                        </UniformGrid>
                                        <TextBlock Text="{Binding StorageStatusText}" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding StoragePath}" Style="{StaticResource MutedText}" Margin="0,14,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_Exports}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <TextBlock Text="{DynamicResource Ui_Folder}" Style="{StaticResource MutedText}" />
                                        <DockPanel Margin="0,6,0,8">
                                            <Button DockPanel.Dock="Right"
                                                    Content="{DynamicResource Ui_Browse}"
                                                    Click="BrowseExportDirectory_Click"
                                                    MinHeight="30"
                                                    Padding="10,0"
                                                    Margin="8,0,0,0" />
                                            <TextBox Text="{Binding ExportDirectoryText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                        </DockPanel>
                                        <UniformGrid Columns="3" Margin="0,0,0,8">
                                            <Button Content="{DynamicResource Ui_SaveFolder}" Click="SaveExportDirectory_Click" Margin="0,0,8,8" />
                                            <Button Content="{DynamicResource Ui_DefaultFolder}" Click="ResetExportDirectory_Click" Margin="0,0,8,8" />
                                            <Button Content="{DynamicResource Ui_OpenFolder}" Click="OpenExportDirectory_Click" Margin="0,0,0,8" />
                                        </UniformGrid>
                                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8">
                                            <Run Text="{DynamicResource Ui_DefaultPrefix}" />
                                            <Run Text="{Binding DefaultExportDirectoryText, Mode=OneWay}" />
                                        </TextBlock>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="{DynamicResource Ui_ExportFiles}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="{DynamicResource Ui_Refresh}" Click="RefreshExports_Click" MinHeight="28" Padding="10,0" Margin="0,0,8,0" />
                                                <Button Content="{DynamicResource Ui_OpenSelected}" Click="OpenSelectedExport_Click" MinHeight="28" Padding="10,0" />
                                            </StackPanel>
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding ExportFiles}"
                                                 SelectedItem="{Binding SelectedExportFile}"
                                                 DisplayMemberPath="DisplayText"
                                                 MinHeight="84"
                                                 MaxHeight="220"
                                                 Background="#11171C"
                                                 BorderBrush="{StaticResource BorderBrushSoft}"
                                                 Foreground="{StaticResource TextBrush}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                        <TextBlock Text="{Binding ExportStatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_Updates}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{DynamicResource Ui_CurrentVersion}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding CurrentVersionText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="{DynamicResource Ui_Latest}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="4" Text="{Binding UpdateLatestVersionText}" VerticalAlignment="Center" />
                                        </Grid>
                                        <CheckBox Content="{DynamicResource Ui_AutoCheckUpdates}"
                                                  IsChecked="{Binding AutomaticallyCheckForUpdates}"
                                                  Margin="0,0,0,10" />
                                        <TextBlock Text="{DynamicResource Ui_ManifestUrl}" Style="{StaticResource MutedText}" />
                                        <TextBox Text="{Binding UpdateManifestUrlText, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="32"
                                                 Margin="0,6,0,10" />
                                        <WrapPanel Margin="0,0,0,10">
                                            <Button Content="{DynamicResource Ui_SaveUpdateSettings}"
                                                    Click="SaveUpdateSettings_Click"
                                                    Margin="0,0,8,8" />
                                            <Button Content="{DynamicResource Ui_CheckUpdates}"
                                                    Click="CheckForUpdates_Click"
                                                    Margin="0,0,8,8" />
                                            <Button Content="{DynamicResource Ui_DownloadRunInstaller}"
                                                    Click="DownloadAndLaunchUpdate_Click"
                                                    IsEnabled="{Binding CanDownloadUpdateInstaller}"
                                                    Margin="0,0,8,8" />
                                            <Button Content="{DynamicResource Ui_SkipVersion}"
                                                    Click="SkipUpdate_Click"
                                                    IsEnabled="{Binding CanSkipAvailableUpdate}"
                                                    Margin="0,0,8,8" />
                                        </WrapPanel>
                                        <TextBlock Text="{Binding UpdateStatusText}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,8"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DownloadedUpdateInstallerPath}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,8"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DownloadedUpdateInstallerPath}" />
                                        <TextBlock Text="{DynamicResource Ui_ReleaseNotes}" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                                        <TextBox Text="{Binding UpdateReleaseNotesText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 MinHeight="72"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</Window>




