                                                        Click="RemoveGlobalWatchSuspicious_Click"
                                                        IsEnabled="{Binding CanRemoveSelectedGlobalProcessSuspicious}"
                                                        Style="{StaticResource TertiaryButton}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                     <Border Margin="0,10,0,0"
                                             Padding="9"
                                             CornerRadius="8"
                                            Background="#12191F"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Ui_Recommendation}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding SelectedGlobalProcessRecommendationText}"
                                                       Style="{StaticResource MutedText}" />
                                            <Button Content="{DynamicResource Ui_OpenRecommendations}"
                                                    Click="OpenRecommendationsForGlobalWatch_Click"
                                                    IsEnabled="{Binding SelectedGlobalProcessHasRecommendation}"
                                                    Style="{StaticResource CompactButton}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding GlobalWatchStatusText}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{DynamicResource Ui_Journal}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Panel}">
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui_WatchJournal}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding GlobalWatchJournalStatusText}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{DynamicResource Ui_GroupedJournalHint}"
                                               Style="{StaticResource MutedText}"
                                               VerticalAlignment="Top" />
                                </DockPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource Panel}">
                                <Grid>
                                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PanningMode="VerticalOnly"
                                                  Visibility="{Binding HasGlobalWatchJournalGroups, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{Binding GlobalWatchJournalGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Expander Margin="0,0,0,10"
                                                              Padding="0"
                                                              Foreground="{StaticResource TextBrush}">
                                                        <Expander.Header>
                                                            <Grid Margin="0,0,8,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding IdentityText}"
                                                                                   FontWeight="SemiBold"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   ToolTip="{Binding IdentityText}"
                                                                                   MaxWidth="320" />
                                                                        <Border Padding="7,2"
                                                                                Margin="10,0,0,0"
                                                                                CornerRadius="7"
                                                                                Background="#17232A"
                                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                                BorderThickness="1">
                                                                            <TextBlock Text="{Binding CountText}" FontSize="11" />
                                                                        </Border>
                                                                        <Border Padding="7,2"
                                                                                Margin="6,0,0,0"
                                                                                CornerRadius="7"
                                                                                BorderThickness="1">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#142A1D" />
                                                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Near">
                                                                                            <Setter Property="Background" Value="#2A2512" />
                                                                                            <Setter Property="BorderBrush" Value="#A88423" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Over">
                                                                                            <Setter Property="Background" Value="#2A1F14" />
                                                                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Critical">
                                                                                            <Setter Property="Background" Value="#2B1719" />
                                                                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Recommendation">
                                                                                            <Setter Property="Background" Value="#14202A" />
                                                                                            <Setter Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding HealthText}"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Reason}"
                                                                               Style="{StaticResource MutedText}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding Reason}"
                                                                               Margin="0,4,0,0" />
                                                                    <TextBlock Text="{Binding MetricsText}"
                                                                               Style="{StaticResource MutedText}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding MetricsText}" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Top">
                                                                    <Button Content="{DynamicResource Ui_Overview}"
                                                                            Click="SelectJournalTarget_Click"
                                                                            Style="{StaticResource CompactButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <Button Content="{DynamicResource Ui_ViewDetails}"
                                                                            Click="InspectJournalTarget_Click"
                                                                            Style="{StaticResource CompactButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <Button Content="{DynamicResource Ui_Suspicious}"
                                                                            Click="MarkJournalSuspicious_Click"
                                                                            Style="{StaticResource CompactButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <ComboBox ItemsSource="{Binding DataContext.ProcessBanDurationOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding DataContext.SelectedProcessBanDurationOption, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                                              DisplayMemberPath="Label"
                                                                              Width="104"
                                                                              MinHeight="26"
                                                                              Margin="0,0,6,0" />
                                                                    <Button Content="{DynamicResource Ui_Ban}"
                                                                            Click="BanJournalTarget_Click"
                                                                            Style="{StaticResource DangerButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <Button Content="{DynamicResource Ui_BanKill}"
                                                                            Click="BanAndKillJournalTarget_Click"
                                                                            Style="{StaticResource DangerButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Expander.Header>
                                                        <ListView ItemsSource="{Binding Entries}"
                                                                  MaxHeight="220"
                                                                  Background="#11171C"
                                                                  BorderBrush="{StaticResource BorderBrushSoft}"
                                                                  Foreground="{StaticResource TextBrush}"
                                                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                            <ListView.View>
                                                                <GridView>
                                                                    <GridViewColumn Header="{DynamicResource Ui_Time}" Width="72" DisplayMemberBinding="{Binding TimestampText}" />
                                                                    <GridViewColumn Header="{DynamicResource Ui_Mode}" Width="96" DisplayMemberBinding="{Binding ModeText}" />
                                                                    <GridViewColumn Header="{DynamicResource Ui_Profile}" Width="170" DisplayMemberBinding="{Binding ProfileText}" />
                                                                    <GridViewColumn Header="{DynamicResource Ui_Metrics}" Width="300" DisplayMemberBinding="{Binding MetricsText}" />
                                                                    <GridViewColumn Header="{DynamicResource Ui_Reason}" Width="360">
                                                                        <GridViewColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding Reason}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           ToolTip="{Binding Reason}" />
                                                                            </DataTemplate>
                                                                        </GridViewColumn.CellTemplate>
                                                                    </GridViewColumn>
                                                                </GridView>
                                                            </ListView.View>
                                                        </ListView>
                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Border Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasGlobalWatchJournalGroups}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{DynamicResource Ui_NoWatchStates}"
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

            <TabItem Header="{DynamicResource Ui_Recommendations}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui_ProfileRecommendations}"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
