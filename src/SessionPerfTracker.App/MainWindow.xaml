<Window x:Class="SessionPerfTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Session Perf Tracker"
        Icon="Assets/app.ico"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="#101317"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="PanelBrush" Color="#171C21" />
        <SolidColorBrush x:Key="PanelStrongBrush" Color="#20262D" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#303941" />
        <SolidColorBrush x:Key="TextBrush" Color="#EDF2F5" />
        <SolidColorBrush x:Key="MutedBrush" Color="#AAB6C0" />
        <SolidColorBrush x:Key="PlaceholderBrush" Color="#8695A1" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#74828D" />
        <SolidColorBrush x:Key="GoodBrush" Color="#3EE079" />
        <SolidColorBrush x:Key="WarnBrush" Color="#F4C542" />
        <SolidColorBrush x:Key="BadBrush" Color="#F05D5E" />
        <SolidColorBrush x:Key="ItemHoverBrush" Color="#202B34" />
        <SolidColorBrush x:Key="ItemSelectedBrush" Color="#26445A" />
        <SolidColorBrush x:Key="ItemSelectedBorderBrush" Color="#4FA0D8" />
        <SolidColorBrush x:Key="TabHoverBrush" Color="#1C252C" />
        <SolidColorBrush x:Key="TabSelectedBrush" Color="#223647" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SummaryTile" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#181F25" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DarkButtonBase" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#242A31" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2E3740" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#4A5B66" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D242B" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#181D22" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#252D34" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource DarkButtonBase}" />

        <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#23563A" />
            <Setter Property="BorderBrush" Value="#3DA76D" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TertiaryButton" TargetType="Button" BasedOn="{StaticResource CompactButton}">
            <Setter Property="Background" Value="#171C21" />
            <Setter Property="BorderBrush" Value="#2A333A" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2B1719" />
            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
        </Style>

        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ClickMode" Value="Press" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="#121920"
                                BorderBrush="#3A4650"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="30" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="9,0,4,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="#B6C3CC"
                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#18232B" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#587080" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#1B2A35" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#181D22" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#252D34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#121920" />
            <Setter Property="BorderBrush" Value="#3A4650" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource ComboBoxToggleButton}"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsEnabled="{TemplateBinding IsEnabled}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#10171D"
                                            BorderBrush="#4FA0D8"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="4">
                                        <ScrollViewer CanContentScroll="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemSelectedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#11171C" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="SelectionBrush" Value="#315E7A" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#4A5B66" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="#181D22" />
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#252D34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="4"
                                    Background="#11171C"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    Margin="0,1,8,0">
                                <Path x:Name="CheckMark"
                                      Data="M 3 8 L 6 11 L 12 4"
                                      Stroke="{StaticResource GoodBrush}"
                                      StrokeThickness="2"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4A5B66" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#142A1D" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#2E8D62" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="Box" Property="Background" Value="#181D22" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#252D34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollBarButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                CornerRadius="4"
                                Background="#42505B" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#5B6D79" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource DarkScrollBarButton}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource DarkScrollBarButton}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="IsDirectionReversed" TargetName="PART_Track" Value="False" />
                                <Setter Property="Height" TargetName="Root" Value="7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#101317" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#11171C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,12,8" />
            <Setter Property="MinWidth" Value="146" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabSelectedBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#11171C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,12" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabSelectedBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding Content}"
                                                  Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource ItemSelectedBrush}" />
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemSelectedBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Background" Value="#141A1F" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="6,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18,14"
                Background="#14191E"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowSessionHeader, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="12"
                        CornerRadius="8"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#171C21" />
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                    <Setter Property="Background" Value="#13241B" />
                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                    <Setter Property="Background" Value="#28230F" />
                                    <Setter Property="BorderBrush" Value="#A88423" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                    <Setter Property="Background" Value="#2B1719" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="9,4"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        Margin="0,0,10,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#20262D" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                                    <Setter Property="Background" Value="#142A1D" />
                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                                    <Setter Property="Background" Value="#2A2512" />
                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                                    <Setter Property="Background" Value="#351B1E" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding LiveSessionStateText}"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                </Border>
                                <TextBlock Text="{Binding LiveSessionTargetText}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="720"
                                           ToolTip="{Binding LiveSessionTargetText}" />
                            </StackPanel>
                            <TextBlock Text="{Binding LiveSessionMetaText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding LiveSessionHintText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,4,0,0" />
                            <Border Visibility="{Binding HasLastCompletedSession, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    CornerRadius="8"
                                    Background="#11171C"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Last completed session" Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding LastCompletedSessionText}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LastCompletedSessionText}" />
                                    <TextBlock Text="{Binding LastCompletedSessionHint}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Margin="18,0,0,0">
                            <TextBlock Text="{Binding DurationText}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding StartedText}"
                                       Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="2" Columns="6">
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="Duration" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding DurationText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="Samples" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding SampleCountText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="Tracked" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding TrackedProcessCountText}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="Events" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding EventCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource WarnBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}">
                        <StackPanel>
                            <TextBlock Text="Breaches" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding BreachCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BadBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryTile}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Hangs" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding HangCountText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BadBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="12,7"
                Background="#12191F"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasCrossScreenMonitoringStrip, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Open Live"
                        Click="OpenLive_Click"
                        Style="{StaticResource CompactButton}" />
                <TextBlock Text="{Binding CrossScreenMonitoringStripText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="2"
                    TabStripPlacement="Left"
                    Padding="14,18,18,18"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="Live">
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <Grid Margin="16,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Padding="12"
                                CornerRadius="8"
                                BorderThickness="1"
                                Margin="0,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#171C21" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="recording">
                                            <Setter Property="Background" Value="#13241B" />
                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="warning">
                                            <Setter Property="Background" Value="#28230F" />
                                            <Setter Property="BorderBrush" Value="#A88423" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LiveSessionStateTone}" Value="danger">
                                            <Setter Property="Background" Value="#2B1719" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Padding="8,3"
                                                CornerRadius="8"
                                                BorderThickness="1"
                                                Margin="0,0,10,0"
                                                Background="#20262D"
                                                BorderBrush="{StaticResource BorderBrushSoft}">
                                            <TextBlock Text="{Binding LiveSessionStateText}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                        </Border>
                                        <TextBlock Text="{Binding LiveSessionTargetText}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="680"
                                                   ToolTip="{Binding LiveSessionTargetText}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding LiveSessionMetaText}"
                                               Style="{StaticResource MutedText}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LiveSessionMetaText}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding LiveSessionHintText}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <UniformGrid Grid.Column="1"
                                             Columns="3"
                                             Margin="18,0,0,0"
                                             VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="Duration" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding DurationText}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="Samples" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding SampleCountText}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Events" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding EventCountText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource WarnBrush}" />
                                    </StackPanel>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,14,0">
                            <StackPanel>
                                <Border Visibility="{Binding HasLiveWarning, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,12"
                                        Padding="10"
                                        CornerRadius="8"
                                        Background="#2B1719"
                                        BorderBrush="{StaticResource BadBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding LiveWarningText}"
                                               Foreground="{StaticResource BadBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="Target" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,6" />
                                <TextBlock Text="Source" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding TargetModes}"
                                          SelectedItem="{Binding SelectedTargetMode}" />
                                <Border Margin="0,10,0,0"
                                        Padding="10"
                                        CornerRadius="8"
                                        Background="#12191F"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TargetReadinessText}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="40"
                                                   ToolTip="{Binding TargetReadinessText}" />
                                        <TextBlock Text="{Binding ActiveThresholdSourceText}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="40"
                                                   ToolTip="{Binding ActiveThresholdSourceText}" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Visibility="{Binding IsRunningProcessMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel Margin="0,12,0,0">
                                        <TextBlock Text="Running process" Style="{StaticResource MutedText}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="Refresh"
                                                Click="RefreshProcesses_Click"
                                                MinHeight="26"
                                                Padding="8,0" />
                                    </DockPanel>
                                    <Grid Margin="0,6,0,0">
                                        <TextBox Text="{Binding ProcessFilterText, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="32" />
                                        <TextBlock Text="Search running processes..."
                                                   IsHitTestVisible="False"
                                                   Foreground="{StaticResource PlaceholderBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProcessFilterText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <ComboBox ItemsSource="{Binding RunningTargets}"
                                              SelectedItem="{Binding SelectedRunningTarget}"
                                              DisplayMemberPath="DisplayName" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsAssignedAppsMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel Margin="0,12,0,0">
                                        <TextBlock Text="Assigned apps / profiles" Style="{StaticResource MutedText}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="Refresh"
                                                Click="RefreshProcesses_Click"
                                                MinHeight="26"
                                                Padding="8,0" />
                                    </DockPanel>
                                    <ComboBox ItemsSource="{Binding AssignedTargets}"
                                              SelectedItem="{Binding SelectedAssignedTarget}"
                                              DisplayMemberPath="DisplayText" />
                                    <TextBlock Text="Assigned apps attach only when the exe is already running."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,6,0,0" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsExecutableMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Manual executable launch" Style="{StaticResource MutedText}" Margin="0,14,0,0" />
                                    <Button Content="Choose EXE"
                                            Click="BrowseExecutable_Click"
                                            Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding SelectedExecutableDisplay}"
                                               Style="{StaticResource MutedText}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                                <TextBlock Text="Session" FontSize="13" FontWeight="SemiBold" Margin="0,18,0,6" />
                                <TextBlock Text="Session profile" Style="{StaticResource MutedText}" />
                                <ComboBox ItemsSource="{Binding SessionProfileOptions}"
                                          SelectedItem="{Binding SelectedSessionProfileOption}"
                                          DisplayMemberPath="DisplayName" />
                                <TextBlock Text="Sampling" Style="{StaticResource MutedText}" Margin="0,12,0,0" />
                                <ComboBox ItemsSource="{Binding SamplingOptions}"
                                          SelectedItem="{Binding SelectedSamplingOption}"
                                          DisplayMemberPath="Label" />
                                <CheckBox Content="Include child processes" IsChecked="{Binding IncludeChildProcesses}" />
                                <CheckBox Content="Live monitor" IsChecked="{Binding IsLiveMonitorEnabled}" />
                                <TextBlock Text="{Binding RecordingStatusText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,10,0,0" />
                                <UniformGrid Columns="2" Margin="0,12,0,0">
                                    <Button Content="Start"
                                            Click="StartRecording_Click"
                                            IsEnabled="{Binding CanStart}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Stop"
                                            Click="StopRecording_Click"
                                            Style="{StaticResource DangerButton}"
                                            IsEnabled="{Binding CanStop}" />
                                </UniformGrid>

                                <TextBlock Text="Assignments" FontSize="13" FontWeight="SemiBold" Margin="0,18,0,6" />
                                <TextBlock Text="Assign current target to profile" Style="{StaticResource MutedText}" />
                                <DockPanel Margin="0,6,0,0">
                                    <Button DockPanel.Dock="Right"
                                            Content="Assign"
                                            Click="AssignCurrentTargetProfile_Click"
                                            MinHeight="30"
                                            Padding="10,0"
                                            Margin="8,0,0,0" />
                                    <ComboBox ItemsSource="{Binding ThresholdProfiles}"
                                              SelectedItem="{Binding SelectedLiveAssignmentProfile}"
                                              DisplayMemberPath="DisplayName" />
                                </DockPanel>
                                <TextBlock Text="{Binding LiveAssignmentStatusText}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="42"
                                           ToolTip="{Binding LiveAssignmentStatusText}"
                                           Margin="0,6,0,0" />

                                <Expander Header="Diagnostics"
                                          Foreground="{StaticResource TextBrush}"
                                          Margin="0,16,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <Button Content="RAM diagnostic snapshot"
                                                Click="CaptureRamDiagnostic_Click" />
                                        <TextBox Text="{Binding RamDiagnosticText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 MinHeight="72"
                                                 MaxHeight="120"
                                                 Margin="0,8,0,0" />
                                        <Button Content="System context snapshot"
                                                Click="CaptureSystemContext_Click"
                                                Margin="0,12,0,0" />
                                        <TextBox Text="{Binding SystemContextText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 MinHeight="72"
                                                 MaxHeight="120"
                                                 Margin="0,8,0,0" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2" Grid.Column="1">
                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14" LastChildFill="False">
                                    <TextBlock Text="{Binding LiveSnapshotTitle}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding LiveSnapshotStatusText}" Style="{StaticResource MutedText}" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding CurrentMetrics}"
                                              Visibility="{Binding HasActiveLiveMetrics, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,10,10"
                                                    Padding="14"
                                                    CornerRadius="8"
                                                    Background="{StaticResource PanelStrongBrush}"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding LiveSnapshotScopeText}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,10" />
                                <Border Visibility="{Binding ShowLiveSnapshotEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Padding="12"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LiveSnapshotEmptyText}"
                                                   Style="{StaticResource MutedText}" />
                                        <UniformGrid Columns="2" Margin="0,10,0,0">
                                            <Border Style="{StaticResource SummaryTile}">
                                                <StackPanel>
                                                    <TextBlock Text="Target" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding LiveConfigTargetText}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding LiveConfigTargetText}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource SummaryTile}" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Collectors" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding LiveConfigCollectorsText}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource SummaryTile}">
                                                <StackPanel>
                                                    <TextBlock Text="Profile" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding ActiveThresholdSourceText}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource SummaryTile}" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Capture" Style="{StaticResource MutedText}" />
                                                    <TextBlock FontWeight="SemiBold">
                                                        <Run Text="{Binding LiveConfigSamplingText, Mode=OneWay}" />
                                                        <Run Text=" / " />
                                                        <Run Text="{Binding LiveConfigChildScopeText, Mode=OneWay}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding LiveConfigMonitorText}" Style="{StaticResource MutedText}" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="Events" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding EventCountText}" Style="{StaticResource MutedText}" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding VisibleEvents}"
                                              Visibility="{Binding HasLiveEvents, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                        <TextBlock Style="{StaticResource MutedText}">
                                                            <Run Text="{Binding Kind, Mode=OneWay}" />
                                                            <Run Text=" / " />
                                                            <Run Text="{Binding Metric, Mode=OneWay}" />
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Details}" Style="{StaticResource MutedText}" />
                                                        <TextBlock Text="{Binding ContextSummaryText}"
                                                                   Style="{StaticResource MutedText}"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding ObservedText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Visibility="{Binding ShowLiveEventEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Padding="16"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding LiveEventEmptyText}"
                                               Style="{StaticResource MutedText}" />
                                </Border>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Global Watch">
                <TabControl Margin="16,0,0,0"
                            TabStripPlacement="Top"
                            Padding="0"
                            SelectedIndex="{Binding SelectedGlobalWatchSectionIndex, Mode=TwoWay}"
                            ItemContainerStyle="{StaticResource SubTabItem}">
                    <TabItem Header="Overview">
                        <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Global Watch"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,0,18,0" />
                                <TextBlock Text="{Binding GlobalWatchLastScanText}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Mode"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <ComboBox ItemsSource="{Binding GlobalWatchModes}"
                                          SelectedItem="{Binding SelectedGlobalWatchMode}"
                                          Width="140"
                                          Margin="0,0,12,0" />
                                <Button Content="Refresh"
                                        Click="RefreshGlobalWatch_Click"
                                        Style="{StaticResource CompactButton}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Top CPU" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding TopCpuOffenders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,3">
                                                <Border DockPanel.Dock="Right"
                                                        Padding="6,1"
                                                        CornerRadius="6"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#142A1D" />
                                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                                    <Setter Property="Background" Value="#2A2512" />
                                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                                    <Setter Property="Background" Value="#2A1F14" />
                                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                                    <Setter Property="Background" Value="#2B1719" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                                </Border>
                                                <TextBlock Text="{Binding TopCpuText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Top RAM" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding TopRamOffenders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,3">
                                                <Border DockPanel.Dock="Right"
                                                        Padding="6,1"
                                                        CornerRadius="6"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#142A1D" />
                                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                                    <Setter Property="Background" Value="#2A2512" />
                                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                                    <Setter Property="Background" Value="#2A1F14" />
                                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                                    <Setter Property="Background" Value="#2B1719" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                                </Border>
                                                <TextBlock Text="{Binding TopRamText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Top Disk" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding TopDiskOffenders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,3">
                                                <Border DockPanel.Dock="Right"
                                                        Padding="6,1"
                                                        CornerRadius="6"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#142A1D" />
                                                            <Setter Property="BorderBrush" Value="#2E8D62" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                                    <Setter Property="Background" Value="#2A2512" />
                                                                    <Setter Property="BorderBrush" Value="#A88423" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                                    <Setter Property="Background" Value="#2A1F14" />
                                                                    <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                                    <Setter Property="Background" Value="#2B1719" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding HealthBadgeText}" FontSize="11" />
                                                </Border>
                                                <TextBlock Text="{Binding TopDiskText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox Text="{Binding GlobalWatchFilterText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="32" />
                            <TextBlock Text="Search process name..."
                                       IsHitTestVisible="False"
                                       Foreground="{StaticResource PlaceholderBrush}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GlobalWatchFilterText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding GlobalWatchSortModes}"
                                  SelectedItem="{Binding SelectedGlobalWatchSortMode}"
                                  Margin="12,0,0,0" />
                        <StackPanel Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <CheckBox Content="Only over limit"
                                      IsChecked="{Binding GlobalWatchOnlyOverLimit}"
                                      Margin="0,0,18,0" />
                            <CheckBox Content="Only critical"
                                      IsChecked="{Binding GlobalWatchOnlyCritical}"
                                      Margin="0,0,18,0" />
                            <CheckBox Content="Only near limit"
                                      IsChecked="{Binding GlobalWatchOnlyNearLimit}"
                                      Margin="0,0,18,0" />
                            <CheckBox Content="Only unassigned"
                                      IsChecked="{Binding GlobalWatchOnlyUnassigned}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Panel}">
                            <Grid>
                                <ListView ItemsSource="{Binding GlobalWatchProcesses}"
                                          SelectedItem="{Binding SelectedGlobalProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="SelectionKey"
                                          IsSynchronizedWithCurrentItem="False"
                                          Background="#11171C"
                                          BorderBrush="{StaticResource BorderBrushSoft}"
                                          Foreground="{StaticResource TextBrush}"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Application / Process" Width="178">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="PID / Count" Width="70" DisplayMemberBinding="{Binding PidOrCountText}" />
                                            <GridViewColumn Header="CPU" Width="58" DisplayMemberBinding="{Binding CpuText}" />
                                            <GridViewColumn Header="RAM" Width="88" DisplayMemberBinding="{Binding MemoryText}" />
                                            <GridViewColumn Header="Disk" Width="82" DisplayMemberBinding="{Binding DiskTotalText}" />
                                            <GridViewColumn Header="Profile" Width="76">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="7,2"
                                                                CornerRadius="7"
                                                                Background="#1B2630"
                                                                BorderBrush="#34566A"
                                                                BorderThickness="1">
                                                            <TextBlock Text="{Binding ProfileBadgeText}"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Health" Width="76">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="7,2"
                                                                CornerRadius="7"
                                                                BorderThickness="1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#142A1D" />
                                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Near">
                                                                            <Setter Property="Background" Value="#2A2512" />
                                                                            <Setter Property="BorderBrush" Value="#A88423" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Over">
                                                                            <Setter Property="Background" Value="#2A1F14" />
                                                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HealthBadgeText}" Value="Critical">
                                                                            <Setter Property="Background" Value="#2B1719" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding HealthBadgeText}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center" />
                                                        </Border>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <Border Padding="18"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasGlobalWatchRows}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding GlobalWatchEmptyStateText}"
                                               Style="{StaticResource MutedText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Panel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedGlobalProcessPanelTitle}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12" />
                                    <TextBlock Text="{Binding SelectedGlobalProcessTitle}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="42"
                                               ToolTip="{Binding SelectedGlobalProcessTitle}" />
                                    <TextBlock Text="{Binding SelectedGlobalProcessHint}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,14" />

                                    <TextBlock Text="Identity"
                                               Style="{StaticResource MutedText}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Product" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SelectedGlobalProcessProductText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding SelectedGlobalProcessProductText}" />
                                        <TextBlock Grid.Row="2" Text="Exe" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGlobalProcessExeText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="4" Text="Path" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="4"
                                                   Grid.Column="1"
                                                   Text="{Binding SelectedGlobalProcessPathText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding SelectedGlobalProcessPathText}" />
                                        <TextBlock Grid.Row="6" Text="Description" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="6"
                                                   Grid.Column="1"
                                                   Text="{Binding SelectedGlobalProcessDescriptionText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding SelectedGlobalProcessDescriptionText}" />
                                        <TextBlock Grid.Row="8" Text="Company" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedGlobalProcessCompanyText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="10" Text="Signer" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding SelectedGlobalProcessSignerText}" />
                                        <TextBlock Grid.Row="12" Text="Parent" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SelectedGlobalProcessParentText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="14" Text="Tree" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding SelectedGlobalProcessDescendantsText}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="16" Text="CPU" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding SelectedGlobalProcessCpuText}" />
                                        <TextBlock Grid.Row="18" Text="RAM" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="18" Grid.Column="1" Text="{Binding SelectedGlobalProcessRamText}" />
                                        <TextBlock Grid.Row="20" Text="Disk R/W" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="20" Grid.Column="1" Text="{Binding SelectedGlobalProcessDiskText}" />
                                        <TextBlock Grid.Row="22" Text="Profile" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="22" Grid.Column="1" Text="{Binding SelectedGlobalProcessProfileText}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="24" Text="Health" Style="{StaticResource MutedText}" />
                                        <Border Grid.Row="24"
                                                Grid.Column="1"
                                                Padding="7,2"
                                                CornerRadius="7"
                                                HorizontalAlignment="Left"
                                                BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#142A1D" />
                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Near">
                                                            <Setter Property="Background" Value="#2A2512" />
                                                            <Setter Property="BorderBrush" Value="#A88423" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Over">
                                                            <Setter Property="Background" Value="#2A1F14" />
                                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedGlobalProcessHealthText}" Value="Critical">
                                                            <Setter Property="Background" Value="#2B1719" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SelectedGlobalProcessHealthText}" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Grid.Row="26" Text="Reason" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="26" Grid.Column="1" Text="{Binding SelectedGlobalProcessReasonText}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="28" Text="Included" Style="{StaticResource MutedText}" />
                                        <TextBlock Grid.Row="28"
                                                   Grid.Column="1"
                                                   Text="{Binding SelectedGlobalProcessIncludedText}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                    <TextBlock Text="Actions"
                                               Style="{StaticResource MutedText}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <Button Content="Monitor this process / group"
                                            Click="MonitorGlobalProcess_Click"
                                            IsEnabled="{Binding CanMonitorSelectedGlobalProcess}" />
                                    <Button Content="View details"
                                            Click="OpenGlobalProcessInspector_Click"
                                            IsEnabled="{Binding CanInspectSelectedGlobalProcess}"
                                            Style="{StaticResource CompactButton}"
                                            Margin="0,8,0,0" />
                                    <UniformGrid Columns="2" Margin="0,8,0,0">
                                        <Button Content="Kill PID"
                                                Click="KillGlobalProcess_Click"
                                                IsEnabled="{Binding CanKillSelectedGlobalProcess}"
                                                Style="{StaticResource DangerButton}"
                                                Margin="0,0,6,0" />
                                        <Button Content="{Binding SelectedGlobalProcessKillTreeLabel}"
                                                Click="KillGlobalProcessTree_Click"
                                                IsEnabled="{Binding CanKillSelectedGlobalProcess}"
                                                Style="{StaticResource DangerButton}" />
                                    </UniformGrid>
                                     <DockPanel Margin="0,10,0,0">
                                         <Button DockPanel.Dock="Right"
                                                 Content="Assign"
                                                 Click="AssignGlobalWatchProfile_Click"
                                                IsEnabled="{Binding CanAssignSelectedGlobalProcessProfile}"
                                                MinHeight="30"
                                                Padding="10,0"
                                                Margin="8,0,0,0" />
                                        <ComboBox ItemsSource="{Binding ThresholdProfiles}"
                                                  SelectedItem="{Binding SelectedLiveAssignmentProfile}"
                                                  DisplayMemberPath="DisplayName"
                                                   IsEnabled="{Binding CanAssignSelectedGlobalProcessProfile}" />
                                     </DockPanel>
                                    <Border Margin="0,10,0,0"
                                            Padding="9"
                                            CornerRadius="8"
                                            Background="#171414"
                                            BorderBrush="{StaticResource BadBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Process ban"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding SelectedGlobalProcessBanText}"
                                                       Style="{StaticResource MutedText}"
                                                       TextWrapping="Wrap" />
                                            <ComboBox ItemsSource="{Binding ProcessBanDurationOptions}"
                                                      SelectedItem="{Binding SelectedProcessBanDurationOption}"
                                                      DisplayMemberPath="Label"
                                                      IsEnabled="{Binding CanBanSelectedGlobalProcess}"
                                                      Margin="0,8,0,0" />
                                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                                <Button Content="Ban"
                                                        Click="BanGlobalProcess_Click"
                                                        IsEnabled="{Binding CanBanSelectedGlobalProcess}"
                                                        Style="{StaticResource CompactButton}"
                                                        Margin="0,0,6,0" />
                                                <Button Content="Ban + kill"
                                                        Click="BanAndKillGlobalProcess_Click"
                                                        IsEnabled="{Binding CanBanSelectedGlobalProcess}"
                                                        Style="{StaticResource DangerButton}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,10,0,0"
                                            Padding="9"
                                            CornerRadius="8"
                                            Background="#12191F"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Suspicious watchlist"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding SelectedGlobalProcessSuspiciousText}"
                                                       Style="{StaticResource MutedText}"
                                                       TextWrapping="Wrap" />
                                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                                <Button Content="Mark"
                                                        Click="MarkGlobalWatchSuspicious_Click"
                                                        IsEnabled="{Binding CanMarkSelectedGlobalProcessSuspicious}"
                                                        Style="{StaticResource CompactButton}"
                                                        Margin="0,0,6,0" />
                                                <Button Content="Remove"
                                                        Click="RemoveGlobalWatchSuspicious_Click"
                                                        IsEnabled="{Binding CanRemoveSelectedGlobalProcessSuspicious}"
                                                        Style="{StaticResource TertiaryButton}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                     <Border Margin="0,10,0,0"
                                             Padding="9"
                                             CornerRadius="8"
                                            Background="#12191F"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Recommendation"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding SelectedGlobalProcessRecommendationText}"
                                                       Style="{StaticResource MutedText}" />
                                            <Button Content="Open Recommendations"
                                                    Click="OpenRecommendationsForGlobalWatch_Click"
                                                    IsEnabled="{Binding SelectedGlobalProcessHasRecommendation}"
                                                    Style="{StaticResource CompactButton}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding GlobalWatchStatusText}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Journal">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Panel}">
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="Watch Journal"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding GlobalWatchJournalStatusText}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="Grouped by process/app branch to reduce duplicate noise"
                                               Style="{StaticResource MutedText}"
                                               VerticalAlignment="Top" />
                                </DockPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource Panel}">
                                <Grid>
                                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PanningMode="VerticalOnly"
                                                  Visibility="{Binding HasGlobalWatchJournalGroups, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{Binding GlobalWatchJournalGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Expander Margin="0,0,0,10"
                                                              Padding="0"
                                                              Foreground="{StaticResource TextBrush}">
                                                        <Expander.Header>
                                                            <Grid Margin="0,0,8,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding IdentityText}"
                                                                                   FontWeight="SemiBold"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   ToolTip="{Binding IdentityText}"
                                                                                   MaxWidth="320" />
                                                                        <Border Padding="7,2"
                                                                                Margin="10,0,0,0"
                                                                                CornerRadius="7"
                                                                                Background="#17232A"
                                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                                BorderThickness="1">
                                                                            <TextBlock Text="{Binding CountText}" FontSize="11" />
                                                                        </Border>
                                                                        <Border Padding="7,2"
                                                                                Margin="6,0,0,0"
                                                                                CornerRadius="7"
                                                                                BorderThickness="1">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#142A1D" />
                                                                                    <Setter Property="BorderBrush" Value="#2E8D62" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Near">
                                                                                            <Setter Property="Background" Value="#2A2512" />
                                                                                            <Setter Property="BorderBrush" Value="#A88423" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Over">
                                                                                            <Setter Property="Background" Value="#2A1F14" />
                                                                                            <Setter Property="BorderBrush" Value="#B66D2A" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Critical">
                                                                                            <Setter Property="Background" Value="#2B1719" />
                                                                                            <Setter Property="BorderBrush" Value="{StaticResource BadBrush}" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding HealthText}" Value="Recommendation">
                                                                                            <Setter Property="Background" Value="#14202A" />
                                                                                            <Setter Property="BorderBrush" Value="{StaticResource ItemSelectedBorderBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding HealthText}"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Reason}"
                                                                               Style="{StaticResource MutedText}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding Reason}"
                                                                               Margin="0,4,0,0" />
                                                                    <TextBlock Text="{Binding MetricsText}"
                                                                               Style="{StaticResource MutedText}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding MetricsText}" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Top">
                                                                    <Button Content="Overview"
                                                                            Click="SelectJournalTarget_Click"
                                                                            Style="{StaticResource CompactButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <Button Content="View details"
                                                                            Click="InspectJournalTarget_Click"
                                                                            Style="{StaticResource CompactButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <Button Content="Suspicious"
                                                                            Click="MarkJournalSuspicious_Click"
                                                                            Style="{StaticResource CompactButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <ComboBox ItemsSource="{Binding DataContext.ProcessBanDurationOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding DataContext.SelectedProcessBanDurationOption, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                                              DisplayMemberPath="Label"
                                                                              Width="104"
                                                                              MinHeight="26"
                                                                              Margin="0,0,6,0" />
                                                                    <Button Content="Ban"
                                                                            Click="BanJournalTarget_Click"
                                                                            Style="{StaticResource DangerButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0"
                                                                            Margin="0,0,6,0" />
                                                                    <Button Content="Ban + kill"
                                                                            Click="BanAndKillJournalTarget_Click"
                                                                            Style="{StaticResource DangerButton}"
                                                                            MinHeight="26"
                                                                            Padding="8,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Expander.Header>
                                                        <ListView ItemsSource="{Binding Entries}"
                                                                  MaxHeight="220"
                                                                  Background="#11171C"
                                                                  BorderBrush="{StaticResource BorderBrushSoft}"
                                                                  Foreground="{StaticResource TextBrush}"
                                                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                            <ListView.View>
                                                                <GridView>
                                                                    <GridViewColumn Header="Time" Width="72" DisplayMemberBinding="{Binding TimestampText}" />
                                                                    <GridViewColumn Header="Mode" Width="96" DisplayMemberBinding="{Binding ModeText}" />
                                                                    <GridViewColumn Header="Profile" Width="170" DisplayMemberBinding="{Binding ProfileText}" />
                                                                    <GridViewColumn Header="Metrics" Width="300" DisplayMemberBinding="{Binding MetricsText}" />
                                                                    <GridViewColumn Header="Reason" Width="360">
                                                                        <GridViewColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding Reason}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           ToolTip="{Binding Reason}" />
                                                                            </DataTemplate>
                                                                        </GridViewColumn.CellTemplate>
                                                                    </GridViewColumn>
                                                                </GridView>
                                                            </ListView.View>
                                                        </ListView>
                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Border Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasGlobalWatchJournalGroups}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="No watch states recorded yet. Global Watch will add grouped Near, Over, Critical and recommendation entries after scans."
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

            <TabItem Header="Recommendations">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0">
                                <StackPanel>
                                    <TextBlock Text="Profile Recommendations"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Repeated profile-limit warnings become reviewable suggestions. Nothing is promoted automatically."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Top">
                                    <Button Content="Promote"
                                            Click="PromoteRecommendation_Click"
                                            Style="{StaticResource PrimaryButton}"
                                            MinHeight="30"
                                            Padding="10,0"
                                            Margin="0,0,8,0" />
                                    <Button Content="Promote selected"
                                            Click="PromoteSelectedRecommendations_Click"
                                            Style="{StaticResource CompactButton}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Ignore selected"
                                            Click="DenySelectedRecommendations_Click"
                                            Style="{StaticResource TertiaryButton}" />
                                </StackPanel>
                            </DockPanel>

                            <WrapPanel Grid.Row="2"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0">
                                <TextBlock Text="Target actions"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Margin="0,0,10,0" />
                                <Button Content="Overview"
                                        Click="SelectRecommendationTarget_Click"
                                        Style="{StaticResource CompactButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <Button Content="View details"
                                        Click="InspectRecommendationTarget_Click"
                                        Style="{StaticResource CompactButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <Button Content="Mark suspicious"
                                        Click="MarkRecommendationSuspicious_Click"
                                        Style="{StaticResource CompactButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <ComboBox ItemsSource="{Binding ProcessBanDurationOptions}"
                                          SelectedItem="{Binding SelectedProcessBanDurationOption}"
                                          DisplayMemberPath="Label"
                                          Width="112"
                                          MinHeight="28"
                                          Margin="0,0,8,6" />
                                <Button Content="Ban"
                                        Click="BanRecommendationTarget_Click"
                                        Style="{StaticResource DangerButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                                <Button Content="Ban + kill"
                                        Click="BanAndKillRecommendationTarget_Click"
                                        Style="{StaticResource DangerButton}"
                                        MinHeight="28"
                                        Padding="9,0"
                                        Margin="0,0,8,6" />
                            </WrapPanel>

                            <ListView x:Name="ProfileRecommendationsList"
                                      Grid.Row="4"
                                      ItemsSource="{Binding ProfileRecommendations}"
                                      SelectedItem="{Binding SelectedProfileRecommendation}"
                                      SelectionMode="Extended"
                                      Background="#11171C"
                                      BorderBrush="{StaticResource BorderBrushSoft}"
                                      Foreground="{StaticResource TextBrush}"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Exe" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                        <GridViewColumn Header="Current profile" Width="190">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding CurrentProfileText}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Suggested" Width="130" DisplayMemberBinding="{Binding SuggestedProfileText}" />
                                        <GridViewColumn Header="Warnings" Width="80" DisplayMemberBinding="{Binding WarningCountText}" />
                                        <GridViewColumn Header="Reason" Width="210">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Reason}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="First seen" Width="140" DisplayMemberBinding="{Binding FirstSeenText}" />
                                        <GridViewColumn Header="Last seen" Width="140" DisplayMemberBinding="{Binding LastSeenText}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock Grid.Row="6"
                                       Text="{Binding ProfileRecommendationStatusText}"
                                       Style="{StaticResource MutedText}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0">
                                <StackPanel>
                                    <TextBlock Text="Denied / Ignored Recommendations"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Ignored exe/profile suggestions stay quiet until you re-enable them."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Remove deny"
                                        Click="RemoveRecommendationDeny_Click"
                                        Style="{StaticResource CompactButton}"
                                        VerticalAlignment="Top" />
                            </DockPanel>

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding DeniedProfileRecommendations}"
                                     SelectedItem="{Binding SelectedDeniedProfileRecommendation}"
                                     DisplayMemberPath="DisplayText"
                                     MinHeight="86"
                                     MaxHeight="180"
                                     Background="#11171C"
                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                     Foreground="{StaticResource TextBrush}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
                    </TabItem>

                    <TabItem Header="Suspicious">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Panel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0">
                                        <StackPanel>
                                            <TextBlock Text="Suspicious Watchlist"
                                                       FontSize="20"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Manual path-based watchlist. Launch transitions are logged when a marked exe appears again."
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Top">
                                            <Button Content="View details"
                                                    Click="InspectSuspiciousWatchItem_Click"
                                                    Style="{StaticResource CompactButton}"
                                                    Margin="0,0,8,0" />
                                            <Button Content="Remove selected"
                                                    Click="RemoveSelectedSuspiciousWatchItem_Click"
                                                    Style="{StaticResource CompactButton}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <ListView Grid.Row="2"
                                              ItemsSource="{Binding SuspiciousWatchItems}"
                                              SelectedItem="{Binding SelectedSuspiciousWatchItem}"
                                              Background="#11171C"
                                              BorderBrush="{StaticResource BorderBrushSoft}"
                                              Foreground="{StaticResource TextBrush}"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasSuspiciousWatchItems, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Exe" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                                <GridViewColumn Header="Product" Width="190">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ProductText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ProductText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Company" Width="170">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding CompanyText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CompanyText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Signer" Width="90" DisplayMemberBinding="{Binding SignerText}" />
                                                <GridViewColumn Header="Marked" Width="145" DisplayMemberBinding="{Binding MarkedAtText}" />
                                                <GridViewColumn Header="Path" Width="300">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding PathText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PathText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>

                                    <Border Grid.Row="2"
                                            Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSuspiciousWatchItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="No suspicious items yet. Select a row in Global Watch Overview and choose Mark."
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Row="4"
                                               Text="{Binding SuspiciousWatchStatusText}"
                                               Style="{StaticResource MutedText}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource Panel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Launch History"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <ListView Grid.Row="2"
                                              ItemsSource="{Binding SuspiciousLaunchEntries}"
                                              Background="#11171C"
                                              BorderBrush="{StaticResource BorderBrushSoft}"
                                              Foreground="{StaticResource TextBrush}"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasSuspiciousLaunchEntries, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Time" Width="145" DisplayMemberBinding="{Binding TimestampText}" />
                                                <GridViewColumn Header="Exe" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                                <GridViewColumn Header="Company" Width="170">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding CompanyText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CompanyText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Signer" Width="90" DisplayMemberBinding="{Binding SignerText}" />
                                                <GridViewColumn Header="Parent" Width="170">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ParentText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ParentText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Mode" Width="110" DisplayMemberBinding="{Binding WatchModeText}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Border Grid.Row="2"
                                            Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSuspiciousLaunchEntries}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="No suspicious launch transitions logged yet."
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Bans">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Panel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0">
                                        <StackPanel>
                                            <TextBlock Text="Process Bans"
                                                       FontSize="20"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Hard path-based rules. Timed rules expire automatically; permanent rules stay until removed here."
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="Remove selected"
                                                Click="RemoveSelectedProcessBan_Click"
                                                IsEnabled="{Binding CanRemoveSelectedProcessBan}"
                                                Style="{StaticResource CompactButton}"
                                                VerticalAlignment="Top" />
                                    </DockPanel>

                                    <ListView Grid.Row="2"
                                              ItemsSource="{Binding ProcessBans}"
                                              SelectedItem="{Binding SelectedProcessBan}"
                                              Background="#11171C"
                                              BorderBrush="{StaticResource BorderBrushSoft}"
                                              Foreground="{StaticResource TextBrush}"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasProcessBans, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Exe" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                                <GridViewColumn Header="Duration" Width="100" DisplayMemberBinding="{Binding DurationText}" />
                                                <GridViewColumn Header="Expires" Width="150" DisplayMemberBinding="{Binding ExpiresText}" />
                                                <GridViewColumn Header="Company" Width="170">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding CompanyText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CompanyText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Signer" Width="110" DisplayMemberBinding="{Binding SignerText}" />
                                                <GridViewColumn Header="Path" Width="360">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding PathText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PathText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>

                                    <Border Grid.Row="2"
                                            Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProcessBans}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="No active process bans. Select a row in Global Watch Overview or Process Inspector, choose duration, then Ban or Ban + kill."
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock Grid.Row="4"
                                               Text="{Binding ProcessBanStatusText}"
                                               Style="{StaticResource MutedText}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource Panel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Ban History"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Created, enforced and removed ban events. This is Global Watch state, separate from Live session events."
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <ListView Grid.Row="2"
                                              ItemsSource="{Binding ProcessBanEvents}"
                                              Background="#11171C"
                                              BorderBrush="{StaticResource BorderBrushSoft}"
                                              Foreground="{StaticResource TextBrush}"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasProcessBanEvents, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Time" Width="145" DisplayMemberBinding="{Binding TimestampText}" />
                                                <GridViewColumn Header="Action" Width="120" DisplayMemberBinding="{Binding ActionText}" />
                                                <GridViewColumn Header="Exe" Width="150" DisplayMemberBinding="{Binding ExeName}" />
                                                <GridViewColumn Header="Duration" Width="100" DisplayMemberBinding="{Binding DurationText}" />
                                                <GridViewColumn Header="Terminated" Width="85" DisplayMemberBinding="{Binding TerminatedText}" />
                                                <GridViewColumn Header="Process" Width="190">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ProcessText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ProcessText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Details" Width="360">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DetailsText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding DetailsText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Border Grid.Row="2"
                                            Padding="18"
                                            CornerRadius="8"
                                            Background="#11171C"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProcessBanEvents}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="No ban events logged yet."
                                                   Style="{StaticResource MutedText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Sessions">
                <Grid Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="Saved Sessions" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Open details"
                                            Click="OpenSessionDetails_Click"
                                            MinHeight="26"
                                            Padding="8,0"
                                            Margin="0,0,8,0" />
                                    <Button Content="Refresh"
                                            Click="RefreshSessions_Click"
                                            MinHeight="26"
                                            Padding="8,0" />
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                <Grid>
                                    <TextBox Text="{Binding SessionSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Text="Search sessions by exe or process..."
                                               IsHitTestVisible="False"
                                               Foreground="{StaticResource PlaceholderBrush}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SessionSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock Text="Profile"
                                               Style="{StaticResource MutedText}"
                                               VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{Binding SessionProfileFilters}"
                                              SelectedItem="{Binding SelectedSessionProfileFilter}"
                                              DisplayMemberPath="Label"
                                              Margin="12,0,0,0" />
                                </DockPanel>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Sessions}"
                                     Grid.Row="2"
                                     SelectedItem="{Binding SelectedSession}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                            <TextBlock Style="{StaticResource MutedText}">
                                                <Run Text="{Binding StartedText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding DurationText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding ChildTrackingText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding SamplingText, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding QualityHint}" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding StabilityText}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Panel}">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="Metric Summary" FontSize="16" FontWeight="SemiBold" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="Export HTML"
                                                Click="ExportSelectedSessionHtml_Click"
                                                MinHeight="28"
                                                Padding="10,0"
                                                Margin="0,0,8,0" />
                                        <Button Content="Export CSV"
                                                Click="ExportSelectedSessionCsv_Click"
                                                MinHeight="28"
                                                Padding="10,0" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="{Binding ExportStatusText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,12" />
                                <Border Padding="12"
                                        Margin="0,0,0,12"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedSession.StabilityText}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SelectedSession.StabilityReason}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding SelectedSession.StartupText}" />
                                            <TextBlock Text="best-effort ready-state" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding SelectedSession.ExitText}" />
                                            <TextBlock Text="based on recorded events" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding SelectedMetricSummaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding MinLabel}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding AvgLabel}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding MaxLabel}" />
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="{Binding SpikeLabel}" />
                                                        <TextBlock Text="{Binding BreachLabel}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Padding="12"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Not collected in this build" Style="{StaticResource MutedText}" />
                                        <ItemsControl ItemsSource="{Binding UnsupportedMetricNotices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Details">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,0,0,0">
                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SessionDetailTitle}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SessionDetailSubtitle}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="Back to Sessions"
                                            Click="BackToSessions_Click"
                                            Style="{StaticResource CompactButton}" />
                                </DockPanel>

                                <TextBlock Text="Select a saved session in Sessions, then open details.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSessionDetails}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl ItemsSource="{Binding SessionDetailFacts}"
                                              Visibility="{Binding HasSessionDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,10,10"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding Value}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="Metric Overview" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="recorded metrics only"
                                               Style="{StaticResource MutedText}" />
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding SessionDetailMetricSummaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.3*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Reliability}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding MinLabel}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding AvgLabel}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding MaxLabel}" />
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="{Binding SpikeLabel}" />
                                                        <TextBlock Text="{Binding BreachLabel}" Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="No recorded metric summaries for this session.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSessionDetailMetrics}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Border Padding="12"
                                        Margin="0,10,0,0"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Not shown as recorded" Style="{StaticResource MutedText}" />
                                        <ItemsControl ItemsSource="{Binding SessionDetailUnsupportedMetricNotices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="Timeline / Event Review" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="chronological"
                                               Style="{StaticResource MutedText}" />
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding SessionDetailEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,10"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                            <TextBlock Style="{StaticResource MutedText}">
                                                                <Run Text="{Binding ElapsedText, Mode=OneWay}" />
                                                                <Run Text=" / " />
                                                                <Run Text="{Binding TimestampText, Mode=OneWay}" />
                                                                <Run Text=" / " />
                                                                <Run Text="{Binding Metric, Mode=OneWay}" />
                                                                <Run Text=" / " />
                                                                <Run Text="{Binding Kind, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding ObservedText}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding ThresholdText}"
                                                                       Style="{StaticResource MutedText}"
                                                                       HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border Margin="0,8,0,0"
                                                            Padding="8"
                                                            CornerRadius="6"
                                                            Background="#1B252D"
                                                            BorderBrush="#34566A"
                                                            BorderThickness="1"
                                                            Visibility="{Binding IsGrouped, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding GroupedText}" Style="{StaticResource MutedText}" />
                                                    </Border>

                                                    <TextBlock Text="{Binding Details}"
                                                               Style="{StaticResource MutedText}"
                                                               Margin="0,8,0,0" />

                                                    <Expander Header="Context around event"
                                                              Foreground="{StaticResource TextBrush}"
                                                              Background="#11171C"
                                                              Margin="0,10,0,0"
                                                              Visibility="{Binding HasContext, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border Padding="10"
                                                                CornerRadius="8"
                                                                Background="#11171C"
                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding ContextCapturedText}" Style="{StaticResource MutedText}" />
                                                                <TextBlock Text="{Binding ContextNoteText}" Style="{StaticResource MutedText}" Margin="0,2,0,10" />

                                                                <TextBlock Text="Top CPU nearby" FontWeight="SemiBold" />
                                                                <ItemsControl ItemsSource="{Binding TopCpuContext}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding SummaryText}"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Text="Top RAM nearby" FontWeight="SemiBold" Margin="0,10,0,0" />
                                                                <ItemsControl ItemsSource="{Binding TopRamContext}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding SummaryText}"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Text="Top Disk nearby" FontWeight="SemiBold" Margin="0,10,0,0" />
                                                                <ItemsControl ItemsSource="{Binding TopDiskContext}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding SummaryText}"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <StackPanel Margin="0,10,0,0"
                                                                            Visibility="{Binding HasNewProcessContext, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock Text="New processes nearby" FontWeight="SemiBold" />
                                                                    <ItemsControl ItemsSource="{Binding NewProcessContext}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="No recorded detector events for this session.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSessionDetailEvents}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Compare">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,0,0,0">
                        <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Left" Style="{StaticResource MutedText}" />
                                    <ComboBox ItemsSource="{Binding Sessions}"
                                              SelectedItem="{Binding CompareLeft}"
                                              DisplayMemberPath="CompareLabel" />
                                    <TextBlock Text="{Binding CompareLeft.StabilityText}" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Right" Style="{StaticResource MutedText}" />
                                    <ComboBox ItemsSource="{Binding Sessions}"
                                              SelectedItem="{Binding CompareRight}"
                                              DisplayMemberPath="CompareLabel" />
                                    <TextBlock Text="{Binding CompareRight.StabilityText}" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="Metric Delta" FontSize="16" FontWeight="SemiBold" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="Export HTML"
                                                Click="ExportCurrentCompareHtml_Click"
                                                MinHeight="28"
                                                Padding="10,0"
                                                Margin="0,0,8,0" />
                                        <Button Content="Export CSV"
                                                Click="ExportCurrentCompareCsv_Click"
                                                MinHeight="28"
                                                Padding="10,0" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="{Binding ExportStatusText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,12" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Metric" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="1" Text="Left avg" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="2" Text="Right avg" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="3" Text="Delta" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="4" Text="Max delta" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="5" Text="Better" Style="{StaticResource MutedText}" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding ComparisonRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12"
                                                    Margin="0,0,0,8"
                                                    CornerRadius="8"
                                                    Background="#141A1F"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Metric}" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding LeftAvg}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding RightAvg}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Delta}" Foreground="{StaticResource WarnBrush}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding MaxDelta}" />
                                                    <TextBlock Grid.Column="5" Text="{Binding Winner}" Foreground="{StaticResource GoodBrush}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Padding="12"
                                        Margin="0,8,0,0"
                                        CornerRadius="8"
                                        Background="#11171C"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Unavailable metrics" Style="{StaticResource MutedText}" />
                                        <ItemsControl ItemsSource="{Binding UnavailableComparisonMetrics}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayText}" Style="{StaticResource MutedText}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Settings">
                <TabControl Margin="16,0,0,0">
                    <TabItem Header="Capture">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Collectors &amp; Capture" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <TextBlock Text="Sampling interval is selected in Live for each session." Style="{StaticResource MutedText}" />
                                        <TextBlock Text="Default 1000 ms; optional 500 ms. Live UI refresh remains separate from collection." Style="{StaticResource MutedText}" Margin="0,4,0,12" />
                                        <UniformGrid Columns="2" Margin="0,0,0,12">
                                            <CheckBox Content="CPU" IsChecked="{Binding CaptureCpu}" />
                                            <CheckBox Content="RAM" IsChecked="{Binding CaptureRam}" />
                                            <CheckBox Content="Disk Read" IsChecked="{Binding CaptureDiskRead}" />
                                            <CheckBox Content="Disk Write" IsChecked="{Binding CaptureDiskWrite}" />
                                        </UniformGrid>
                                        <TextBlock Text="GPU and temperature collectors are not implemented yet." Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                                        <Button Content="Save capture scope"
                                                Click="SaveCaptureSettings_Click"
                                                HorizontalAlignment="Left" />
                                        <TextBlock Text="{Binding ThresholdSettingsStatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />

                                        <TextBlock Text="Anti-noise" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,12" />
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Startup grace, s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding StartupGraceSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <TextBlock Grid.Column="3" Text="Cooldown, s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="4" Text="{Binding EventCooldownSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <TextBlock Grid.Row="2" Text="Grouping, s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding GroupingWindowSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Snapshot suppress, s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding SnapshotSuppressionSecondsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            <Button Grid.Row="4" Grid.ColumnSpan="6" Content="Save anti-noise" Click="SaveAntiNoiseSettings_Click" HorizontalAlignment="Left" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Self-Monitoring" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="SessionPerfTracker process" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding SelfMonitoringStatusText}" Style="{StaticResource MutedText}" />
                                        </DockPanel>
                                        <UniformGrid Columns="2" Margin="0,0,0,18">
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="CPU now / avg / peak" Style="{StaticResource MutedText}" />
                                                <TextBlock>
                                                    <Run Text="{Binding SelfCurrentCpuText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfAvgCpuText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfPeakCpuText, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="RAM now / avg / peak" Style="{StaticResource MutedText}" />
                                                <TextBlock>
                                                    <Run Text="{Binding SelfCurrentRamText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfAvgRamText, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelfPeakRamText, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Self disk write" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfDiskWriteText}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Samples" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfSampleCountText}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="Overhead Budget" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Avg CPU &lt; 2%" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfCpuBudgetStatusText}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="Peak RAM &lt; 150 MB" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfRamBudgetStatusText}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Writes batched" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfWritesBudgetStatusText}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Deep snapshots" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding SelfSnapshotsBudgetStatusText}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <Border Margin="0,18,0,0"
                                                Padding="12"
                                                CornerRadius="8"
                                                Background="#11171C"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="App behavior" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <CheckBox Content="Keep running in background when closed"
                                                          IsChecked="{Binding MinimizeToTrayOnClose}" />
                                                <TextBlock Text="When enabled, the window close button hides the app to the system tray. Use tray Exit to quit."
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,6,0,10" />
                                                <Button Content="Save app behavior"
                                                        Click="SaveAppBehaviorSettings_Click"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource CompactButton}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Profiles">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <Border Style="{StaticResource Panel}">
                                <StackPanel>
                                <TextBlock Text="Threshold Profiles" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                <TextBlock Text="Global fallback" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU %" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding CpuThresholdPercentText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Column="3" Text="RAM MB" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="4"
                                             Text="{Binding RamThresholdMbText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="2" Text="Disk read MB/s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding DiskReadThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Disk write MB/s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="4"
                                             Text="{Binding DiskWriteThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <Button Grid.Column="5"
                                            Grid.RowSpan="3"
                                            Content="Save fallback"
                                            Click="SaveThresholdSettings_Click"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="14,0,0,0" />
                                </Grid>

                                <Grid Margin="0,0,0,18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Selected profile" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              Grid.ColumnSpan="2"
                                              ItemsSource="{Binding ThresholdProfiles}"
                                              SelectedItem="{Binding SelectedThresholdProfile}"
                                              DisplayMemberPath="DisplayName"
                                              Margin="0" />
                                    <Button Grid.Column="3"
                                            Content="Reset selected"
                                            Click="ResetSelectedProfile_Click"
                                            HorizontalAlignment="Left" />
                                    <Button Grid.Column="4"
                                            Grid.ColumnSpan="2"
                                            Content="Reset all thresholds"
                                            Click="ResetAllThresholdSettings_Click"
                                            HorizontalAlignment="Left" />

                                    <TextBlock Grid.Row="2" Text="CPU %" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding ProfileCpuThresholdPercentText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="RAM MB" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="4"
                                             Text="{Binding ProfileRamThresholdMbText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />

                                    <TextBlock Grid.Row="4" Text="Disk read MB/s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             Text="{Binding ProfileDiskReadThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Disk write MB/s" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="4"
                                             Grid.Column="4"
                                             Text="{Binding ProfileDiskWriteThresholdMbPerSecText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <Button Grid.Row="4"
                                            Grid.Column="5"
                                            Content="Save profile"
                                            Click="SaveSelectedProfile_Click"
                                            HorizontalAlignment="Left"
                                            Margin="14,0,0,0" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="App assignment" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding AssignmentExeNameText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32" />
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding ThresholdProfiles}"
                                              SelectedItem="{Binding SelectedAssignmentProfile}"
                                              DisplayMemberPath="DisplayName"
                                              Margin="0" />
                                    <Button Grid.Column="4"
                                            Content="Assign"
                                            Click="SaveAppProfileAssignment_Click"
                                            HorizontalAlignment="Left"
                                            Margin="14,0,0,0" />
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ListBox ItemsSource="{Binding AppProfileAssignments}"
                                             SelectedItem="{Binding SelectedAppProfileAssignment}"
                                             DisplayMemberPath="DisplayText"
                                             MinHeight="72"
                                             MaxHeight="140"
                                             Background="#11171C"
                                             BorderBrush="{StaticResource BorderBrushSoft}"
                                             Foreground="{StaticResource TextBrush}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    <Button Grid.Column="1"
                                            Content="Remove assignment"
                                            Click="RemoveAppProfileAssignment_Click"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="14,0,0,0" />
                                </Grid>
                                <TextBlock Text="{Binding ThresholdSettingsStatusText}" Style="{StaticResource MutedText}" Margin="0,0,0,18" />

                            </StackPanel>
                        </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Storage">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Storage / Retention" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="Retention" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <Button DockPanel.Dock="Right"
                                                    Content="Save"
                                                    Click="SaveRetentionSettings_Click"
                                                    MinHeight="30"
                                                    Padding="10,0"
                                                    Margin="8,0,0,0" />
                                            <ComboBox ItemsSource="{Binding RetentionOptions}"
                                                      SelectedItem="{Binding SelectedRetentionOption}"
                                                      DisplayMemberPath="Label"
                                                      Margin="12,0,0,0" />
                                        </DockPanel>
                                        <UniformGrid Columns="2" Margin="0,0,0,8">
                                            <Button Content="Delete all sessions" Click="DeleteAllSessions_Click" Margin="0,0,8,8" />
                                            <Button Content="Delete filtered sessions" Click="DeleteFilteredSessions_Click" Margin="0,0,0,8" />
                                            <Button Content="Delete older than 1 day" Click="DeleteSessionsOlderThan1Day_Click" Margin="0,0,8,8" />
                                            <Button Content="Delete older than 7 days" Click="DeleteSessionsOlderThan7Days_Click" Margin="0,0,0,8" />
                                            <Button Content="Delete older than 30 days" Click="DeleteSessionsOlderThan30Days_Click" Margin="0,0,8,0" />
                                        </UniformGrid>
                                        <TextBlock Text="{Binding StorageStatusText}" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding StoragePath}" Style="{StaticResource MutedText}" Margin="0,14,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Exports" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <TextBlock Text="Folder" Style="{StaticResource MutedText}" />
                                        <DockPanel Margin="0,6,0,8">
                                            <Button DockPanel.Dock="Right"
                                                    Content="Browse"
                                                    Click="BrowseExportDirectory_Click"
                                                    MinHeight="30"
                                                    Padding="10,0"
                                                    Margin="8,0,0,0" />
                                            <TextBox Text="{Binding ExportDirectoryText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                        </DockPanel>
                                        <UniformGrid Columns="3" Margin="0,0,0,8">
                                            <Button Content="Save folder" Click="SaveExportDirectory_Click" Margin="0,0,8,8" />
                                            <Button Content="Default folder" Click="ResetExportDirectory_Click" Margin="0,0,8,8" />
                                            <Button Content="Open folder" Click="OpenExportDirectory_Click" Margin="0,0,0,8" />
                                        </UniformGrid>
                                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8">
                                            <Run Text="Default: " />
                                            <Run Text="{Binding DefaultExportDirectoryText, Mode=OneWay}" />
                                        </TextBlock>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="Export files" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="Refresh" Click="RefreshExports_Click" MinHeight="28" Padding="10,0" Margin="0,0,8,0" />
                                                <Button Content="Open selected" Click="OpenSelectedExport_Click" MinHeight="28" Padding="10,0" />
                                            </StackPanel>
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding ExportFiles}"
                                                 SelectedItem="{Binding SelectedExportFile}"
                                                 DisplayMemberPath="DisplayText"
                                                 MinHeight="84"
                                                 MaxHeight="220"
                                                 Background="#11171C"
                                                 BorderBrush="{StaticResource BorderBrushSoft}"
                                                 Foreground="{StaticResource TextBrush}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                        <TextBlock Text="{Binding ExportStatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Updates" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Current version" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding CurrentVersionText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="Latest" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="4" Text="{Binding UpdateLatestVersionText}" VerticalAlignment="Center" />
                                        </Grid>
                                        <CheckBox Content="Automatically check for updates"
                                                  IsChecked="{Binding AutomaticallyCheckForUpdates}"
                                                  Margin="0,0,0,10" />
                                        <TextBlock Text="Manifest URL / local version.json path" Style="{StaticResource MutedText}" />
                                        <TextBox Text="{Binding UpdateManifestUrlText, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="32"
                                                 Margin="0,6,0,10" />
                                        <WrapPanel Margin="0,0,0,10">
                                            <Button Content="Save update settings"
                                                    Click="SaveUpdateSettings_Click"
                                                    Margin="0,0,8,8" />
                                            <Button Content="Check for updates"
                                                    Click="CheckForUpdates_Click"
                                                    Margin="0,0,8,8" />
                                            <Button Content="Download and run installer"
                                                    Click="DownloadAndLaunchUpdate_Click"
                                                    IsEnabled="{Binding CanDownloadUpdateInstaller}"
                                                    Margin="0,0,8,8" />
                                        </WrapPanel>
                                        <TextBlock Text="{Binding UpdateStatusText}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,8"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DownloadedUpdateInstallerPath}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,8"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DownloadedUpdateInstallerPath}" />
                                        <TextBlock Text="Release notes" Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                                        <TextBox Text="{Binding UpdateReleaseNotesText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 MinHeight="72"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
